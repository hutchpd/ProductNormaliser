@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="notice error" role="alert"></div>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Quick Navigation</p>
                <h2>Jump into the dashboard areas</h2>
            </div>
        </div>
        <div class="quick-links">
            <a class="card-link" asp-page="/Categories/Index">
                <strong>Categories</strong>
                <span class="subtle-copy">Review enabled families and schemas.</span>
            </a>
            <a class="card-link" asp-page="/CrawlJobs/Index">
                <strong>Crawl Jobs</strong>
                <span class="subtle-copy">Launch and monitor job batches.</span>
            </a>
            <a class="card-link" asp-page="/Products/Index">
                <strong>Products</strong>
                <span class="subtle-copy">Inspect canonical product merges.</span>
            </a>
            <a class="card-link" asp-page="/Sources/Index">
                <strong>Sources</strong>
                <span class="subtle-copy">Check registry coverage and health.</span>
            </a>
        </div>
    </section>

    <div class="overview-grid">
        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Selected Category</p>
                    <h2>Schema detail and launch controls</h2>
                </div>
                <form method="get" class="category-picker">
                    <label asp-for="SelectedCategoryKey" class="form-label">Category</label>
                    <select asp-for="SelectedCategoryKey" class="form-select" onchange="this.form.submit()">
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.CategoryKey">@category.DisplayName</option>
                        }
                    </select>
                </form>
            </div>

            @if (Model.SelectedCategory is null)
            {
                <div class="empty-panel">
                    <p class="empty-state">No category detail is currently available from the Admin API.</p>
                </div>
            }
            else
            {
                <div class="chip-row">
                    <span class="chip">@Model.SelectedCategory.Metadata.FamilyDisplayName</span>
                    <span class="chip">Support: @Model.SelectedCategory.Metadata.CrawlSupportStatus</span>
                    <span class="chip">Completeness: @Model.SelectedCategory.Metadata.SchemaCompletenessScore</span>
                </div>

                <dl class="detail-grid">
                    <div>
                        <dt>Category key</dt>
                        <dd>@Model.SelectedCategory.Metadata.CategoryKey</dd>
                    </div>
                    <div>
                        <dt>Attributes</dt>
                        <dd>@Model.SelectedCategory.Schema.Attributes.Count</dd>
                    </div>
                    <div>
                        <dt>Enabled</dt>
                        <dd>@(Model.SelectedCategory.Metadata.IsEnabled ? "Yes" : "No")</dd>
                    </div>
                    <div>
                        <dt>Icon key</dt>
                        <dd>@Model.SelectedCategory.Metadata.IconKey</dd>
                    </div>
                </dl>

                <form method="post" asp-page-handler="LaunchCategoryCrawl" class="source-form">
                    <input asp-for="QuickCrawl.CategoryKey" type="hidden" value="@Model.SelectedCategory.Metadata.CategoryKey" />
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Launch Category Crawl</button>
                    </div>
                    <span asp-validation-for="QuickCrawl.CategoryKey" class="text-danger small"></span>
                </form>

                <div class="table-wrap mt-3">
                    <table class="table dashboard-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Attribute</th>
                                <th>Type</th>
                                <th>Unit</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var schemaField in Model.SelectedCategory.Schema.Attributes.Take(8))
                        {
                            <tr>
                                <td>
                                    <strong>@schemaField.DisplayName</strong>
                                    <div class="text-muted small">@schemaField.Key</div>
                                </td>
                                <td>@schemaField.ValueType</td>
                                <td>@(schemaField.Unit ?? "-")</td>
                                <td>@(schemaField.IsRequired ? "Required" : "Optional")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <div class="stacked-panels">
            <section class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Catalogue Health</p>
                        <h2>Current product metrics</h2>
                    </div>
                </div>
                <div class="metric-strip">
                    <article>
                        <span>Source products</span>
                        <strong>@Model.Stats.TotalSourceProducts</strong>
                    </article>
                    <article>
                        <span>Avg attributes</span>
                        <strong>@Model.Stats.AverageAttributesPerProduct</strong>
                    </article>
                    <article>
                        <span>Conflict rate</span>
                        <strong>@Model.Stats.PercentProductsWithConflicts%</strong>
                    </article>
                    <article>
                        <span>Missing key fields</span>
                        <strong>@Model.Stats.PercentProductsMissingKeyAttributes%</strong>
                    </article>
                </div>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Recent Crawl Jobs</p>
                        <h2>Latest activity</h2>
                    </div>
                    <a class="btn btn-outline-dark btn-sm" asp-page="/CrawlJobs/Index">Open job history</a>
                </div>

                @if (Model.RecentJobs.Count == 0)
                {
                    <div class="empty-panel">
                        <p class="empty-state">No crawl jobs have been created yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="table dashboard-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Job</th>
                                    <th>Scope</th>
                                    <th>Status</th>
                                    <th>Progress</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var job in Model.RecentJobs)
                            {
                                <tr>
                                    <td>
                                        <a class="mono" asp-page="/CrawlJobs/Index" asp-route-jobId="@job.JobId">@job.JobId</a>
                                    </td>
                                    <td>@job.RequestType</td>
                                    <td>@job.Status</td>
                                    <td>@job.ProcessedTargets / @job.TotalTargets</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    </div>

    <section class="panel panel-register">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Register Source</p>
                <h2>Seed a managed crawl source</h2>
            </div>
            <a class="btn btn-outline-dark btn-sm" asp-page="/Sources/Index">View all sources</a>
        </div>

        <form method="post" asp-page-handler="RegisterSource" class="source-form">
            <div class="form-grid">
                <div>
                    <label asp-for="RegisterSource.SourceId" class="form-label"></label>
                    <input asp-for="RegisterSource.SourceId" class="form-control" placeholder="ao_uk" />
                    <span asp-validation-for="RegisterSource.SourceId" class="text-danger small"></span>
                </div>
                <div>
                    <label asp-for="RegisterSource.DisplayName" class="form-label"></label>
                    <input asp-for="RegisterSource.DisplayName" class="form-control" placeholder="AO UK" />
                    <span asp-validation-for="RegisterSource.DisplayName" class="text-danger small"></span>
                </div>
                <div class="wide">
                    <label asp-for="RegisterSource.BaseUrl" class="form-label"></label>
                    <input asp-for="RegisterSource.BaseUrl" class="form-control" placeholder="https://ao.com/" />
                    <span asp-validation-for="RegisterSource.BaseUrl" class="text-danger small"></span>
                </div>
                <div class="wide">
                    <label asp-for="RegisterSource.Description" class="form-label"></label>
                    <textarea asp-for="RegisterSource.Description" class="form-control" rows="2" placeholder="Optional operational notes"></textarea>
                </div>
            </div>

            <div class="section-divider"></div>

            <div class="form-grid compact-grid">
                <div>
                    <label asp-for="RegisterSource.MinDelayMs" class="form-label"></label>
                    <input asp-for="RegisterSource.MinDelayMs" class="form-control" />
                </div>
                <div>
                    <label asp-for="RegisterSource.MaxDelayMs" class="form-label"></label>
                    <input asp-for="RegisterSource.MaxDelayMs" class="form-control" />
                </div>
                <div>
                    <label asp-for="RegisterSource.MaxConcurrentRequests" class="form-label"></label>
                    <input asp-for="RegisterSource.MaxConcurrentRequests" class="form-control" />
                </div>
                <div>
                    <label asp-for="RegisterSource.RequestsPerMinute" class="form-label"></label>
                    <input asp-for="RegisterSource.RequestsPerMinute" class="form-control" />
                </div>
            </div>

            <div class="toggle-row">
                <label class="form-check">
                    <input asp-for="RegisterSource.IsEnabled" class="form-check-input" />
                    <span class="form-check-label">Enable immediately</span>
                </label>
                <label class="form-check">
                    <input asp-for="RegisterSource.RespectRobotsTxt" class="form-check-input" />
                    <span class="form-check-label">Respect robots.txt</span>
                </label>
            </div>

            <div>
                <p class="form-label mb-2">Supported categories</p>
                <div class="check-grid">
                @foreach (var category in Model.Categories.Where(category => category.IsEnabled))
                {
                    <label class="check-card">
                        <input type="checkbox" name="RegisterSource.SelectedCategoryKeys" value="@category.CategoryKey" checked="@Model.RegisterSource.SelectedCategoryKeys.Contains(category.CategoryKey)" />
                        <span>@category.DisplayName</span>
                    </label>
                }
                </div>
                <span asp-validation-for="RegisterSource.SelectedCategoryKeys" class="text-danger small"></span>
            </div>

            <div class="actions-bar">
                <button type="submit" class="btn btn-dark">Register Source</button>
            </div>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
