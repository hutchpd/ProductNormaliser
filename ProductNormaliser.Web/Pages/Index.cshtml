@page
@model IndexModel
@{
    ViewData["Title"] = "Operator Console";
}

<section class="dashboard-shell operator-console-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="notice error" role="alert"></div>

    @if (Model.LandingState == IndexModel.OperatorLandingState.Loading)
    {
        <section class="panel panel-muted">
            <div class="empty-panel">
                <p class="empty-state">Loading operator console...</p>
            </div>
        </section>
    }
    else
    {
        <section class="panel operator-context-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Current Category Context</p>
                    <h2>Operate from one deliberate landing surface</h2>
                    <p class="subtle-copy">The landing page keeps crawl launch, job monitoring, product review, quality signals, and source posture aligned to the current category context.</p>
                </div>
                <a href="@Model.CategorySelectionUrl" class="btn btn-outline-dark btn-sm">Refine category set</a>
            </div>

            @if (!Model.HasCategoryContext)
            {
                <div class="empty-panel">
                    <p class="empty-state">No category context is selected yet. Start with category selection to stage crawl, product, quality, and source workflows.</p>
                </div>
            }
            else
            {
                <div class="operator-context-grid">
                    <article class="operator-context-card">
                        <span class="eyebrow">Selected categories</span>
                        <strong>@Model.CurrentCategoryContext!.SelectionSummary</strong>
                        <p class="subtle-copy">Primary category: @Model.SelectedCategory?.Metadata.DisplayName</p>
                        <div class="chip-row">
                            @foreach (var category in Model.CurrentCategoryContext.SelectedCategories)
                            {
                                <span class="chip">@category.DisplayName</span>
                            }
                        </div>
                    </article>

                    <article class="operator-context-card">
                        <span class="eyebrow">Quick Crawl Launch</span>
                        <strong>Start a category crawl immediately</strong>
                        <p class="subtle-copy">This launches the current primary category and keeps the rest of the selected set available in the crawl console.</p>
                        <form method="post" asp-page-handler="LaunchCategoryCrawl" class="operator-inline-form">
                            <input asp-for="QuickCrawl.CategoryKey" type="hidden" value="@Model.SelectedCategoryKey" />
                            <button type="submit" class="btn btn-dark">Launch current category crawl</button>
                        </form>
                    </article>

                    <article class="operator-context-card">
                        <span class="eyebrow">Source Coverage</span>
                        <strong>@Model.CategorySources.Count sources in scope</strong>
                        <p class="subtle-copy">@Model.ReadyCategorySourceCount crawl-ready, @Model.AttentionCategorySourceCount needing attention.</p>
                    </article>
                </div>
            }
        </section>

        <section class="panel panel-muted">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Boot And Populate</p>
                    <h2>Current startup path</h2>
                </div>
                <a href="@Model.SourcesUrl" class="btn btn-outline-dark btn-sm">Prepare sources</a>
            </div>

            <div class="metric-strip">
                <article>
                    <span>Boot-ready sources</span>
                    <strong>@Model.BootReadyCategorySourceCount</strong>
                </article>
                <article>
                    <span>Categories in context</span>
                    <strong>@(Model.CurrentCategoryContext?.SelectedCategoryKeys.Count ?? 0)</strong>
                </article>
                <article>
                    <span>Estimated seeds</span>
                    <strong>@Model.EstimatedContextSeedCount</strong>
                </article>
                <article>
                    <span>Confirmed products 24h</span>
                    <strong>@Model.Stats.ConfirmedProductUrlCountLast24Hours</strong>
                </article>
            </div>

            <p class="subtle-copy mt-3">The intended path is: register or enable sources, choose categories, start a crawl job, then watch discovery queue depth, confirmed product targets, and canonical product counts move together from this console and the crawl-job detail view.</p>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Primary Actions</p>
                    <h2>Main operator paths</h2>
                </div>
            </div>

            <div class="operator-action-grid">
                @foreach (var actionCard in Model.ActionCards)
                {
                    <partial name="_OperatorActionCard" model="actionCard" />
                }
            </div>
        </section>

        <div class="operator-landing-grid">
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Operational Health</p>
                        <h2>Runtime queue and failure posture</h2>
                    </div>
                    <a href="@Model.CrawlJobsUrl" class="btn btn-outline-dark btn-sm">Inspect jobs</a>
                </div>

                <div class="operator-summary-grid compact">
                    @foreach (var summaryCard in Model.OperationalHealthCards)
                    {
                        <partial name="_OperatorSummaryCard" model="summaryCard" />
                    }
                </div>

                <div class="panel panel-muted mt-3">
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Discovery Health</p>
                            <h2>Frontier activity and promotion posture</h2>
                        </div>
                    </div>

                    <div class="operator-summary-grid compact">
                        @foreach (var summaryCard in Model.DiscoverySummaryCards)
                        {
                            <partial name="_OperatorSummaryCard" model="summaryCard" />
                        }
                    </div>
                </div>

                <div class="operator-landing-grid mt-3">
                    <section class="panel panel-muted">
                        <div class="panel-heading">
                            <div>
                                <p class="eyebrow">At-Risk Sources</p>
                                <h2>Source failure and retry hotspots</h2>
                            </div>
                            <a href="@Model.SourceIntelligenceUrl" class="btn btn-outline-dark btn-sm">Open source intelligence</a>
                        </div>

                        @if (Model.AtRiskOperationalSources.Count == 0)
                        {
                            <div class="empty-panel">
                                <p class="empty-state">No sources are currently showing retry backlog or elevated failure posture.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-wrap">
                                <table class="table dashboard-table align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Source</th>
                                            <th>Health</th>
                                            <th>Queue</th>
                                            <th>Retries</th>
                                            <th>Failures 24h</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var source in Model.AtRiskOperationalSources)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@source.SourceName</strong>
                                                <div class="subtle-copy">Trust @source.TrustScore.ToString("0.#")%, success @source.SuccessfulCrawlRate.ToString("0.#")%</div>
                                            </td>
                                            <td>@source.HealthStatus</td>
                                            <td>@source.QueueDepth</td>
                                            <td>@source.RetryQueueDepth</td>
                                            <td>@source.FailedCrawlsLast24Hours (@source.FailureRateLast24Hours.ToString("0.#")%)</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </section>

                    <section class="panel panel-muted">
                        <div class="panel-heading">
                            <div>
                                <p class="eyebrow">Category Pressure</p>
                                <h2>Where crawl load is concentrating</h2>
                            </div>
                            <a href="@Model.QualityUrl" class="btn btn-outline-dark btn-sm">Open quality lens</a>
                        </div>

                        @if (Model.BusyOperationalCategories.Count == 0)
                        {
                            <div class="empty-panel">
                                <p class="empty-state">No category-level queue pressure or recent failures are currently reported.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-wrap">
                                <table class="table dashboard-table align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Category</th>
                                            <th>Discovery</th>
                                            <th>Confirmed</th>
                                            <th>Active jobs</th>
                                            <th>Queues</th>
                                            <th>Retries</th>
                                            <th>Failures 24h</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var category in Model.BusyOperationalCategories)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="mono">@category.CategoryKey</strong>
                                                <div class="subtle-copy">@category.ActiveSourceCoverage of @category.DistinctSourceCount active sources, @category.CrawledProductUrlCountLast24Hours crawled products in 24h</div>
                                            </td>
                                            <td>@category.DiscoveredUrlCount</td>
                                            <td>@category.ConfirmedProductTargetCount</td>
                                            <td>@category.ActiveJobCount</td>
                                            <td>@category.DiscoveryQueueDepth / @category.QueueDepth</td>
                                            <td>@category.RetryQueueDepth</td>
                                            <td>@category.FailedCrawlsLast24Hours (@category.FailureRateLast24Hours.ToString("0.#")%)</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </section>
                </div>
            </section>

            <section class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Product Counts</p>
                        <h2>Catalogue operating signals</h2>
                    </div>
                    <a href="@Model.ProductsUrl" class="btn btn-outline-dark btn-sm">Explore products</a>
                </div>

                <div class="operator-summary-grid">
                    @foreach (var summaryCard in Model.ProductSummaryCards)
                    {
                        <partial name="_OperatorSummaryCard" model="summaryCard" />
                    }
                </div>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Category Discovery</p>
                        <h2>Selected category progress cards</h2>
                    </div>
                </div>

                @if (Model.SelectedCategoryOperationalMetrics.Count == 0)
                {
                    <div class="empty-panel">
                        <p class="empty-state">No discovery metrics are available for the current category selection yet.</p>
                    </div>
                }
                else
                {
                    <div class="job-card-grid">
                        @foreach (var category in Model.SelectedCategoryOperationalMetrics)
                        {
                            <article class="job-card">
                                <div class="job-card-header">
                                    <div>
                                        <strong class="mono">@category.CategoryKey</strong>
                                        <div class="subtle-copy">@category.ActiveSourceCoverage active of @category.DistinctSourceCount participating sources</div>
                                    </div>
                                    <span class="status-pill @(category.DiscoveryQueueDepth == 0 ? "completed" : "warning")">@category.DiscoveryCompletionPercent.ToString("0.#")% complete</span>
                                </div>

                                <dl class="detail-grid compact-grid mt-3">
                                    <div>
                                        <dt>Discovered URLs</dt>
                                        <dd>@category.DiscoveredUrlCount</dd>
                                    </div>
                                    <div>
                                        <dt>Confirmed products</dt>
                                        <dd>@category.ConfirmedProductTargetCount</dd>
                                    </div>
                                    <div>
                                        <dt>Crawled products</dt>
                                        <dd>@category.CrawledProductUrlCountLast24Hours</dd>
                                    </div>
                                    <div>
                                        <dt>Discovery queue</dt>
                                        <dd>@category.DiscoveryQueueDepth</dd>
                                    </div>
                                    <div>
                                        <dt>Product queue</dt>
                                        <dd>@category.QueueDepth</dd>
                                    </div>
                                    <div>
                                        <dt>Failures 24h</dt>
                                        <dd>@category.FailedCrawlsLast24Hours</dd>
                                    </div>
                                </dl>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Active Crawl Jobs</p>
                        <h2>Work in flight</h2>
                    </div>
                    <a href="@Model.CrawlJobsUrl" class="btn btn-outline-dark btn-sm">View jobs</a>
                </div>

                @if (Model.ActiveJobs.Count == 0)
                {
                    <div class="empty-panel">
                        <p class="empty-state">No active crawl jobs are running right now.</p>
                    </div>
                }
                else
                {
                    <div class="job-card-grid">
                        @foreach (var job in Model.ActiveJobs)
                        {
                            <article class="job-card">
                                <div class="job-card-header">
                                    <div>
                                        <strong class="mono">@job.JobId</strong>
                                        <div class="subtle-copy">@ProductNormaliser.Web.Models.CrawlJobPresentation.GetRequestedCategoriesSummary(job)</div>
                                    </div>
                                    <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.CrawlJobPresentation.GetStatusBadge(job.Status)" />
                                </div>

                                <div class="progress-shell">
                                    <div class="progress-bar-shell">
                                        <div class="progress-bar-fill" style="width: @job.DiscoveryCompletionPercent%"></div>
                                    </div>
                                    <div class="subtle-copy">Discovery @job.ProcessedTargets of @job.TotalTargets processed, @job.ConfirmedProductTargetCount confirmed products, @job.ProductQueueDepth still queued, @job.RejectedPageCount rejected, @job.BlockedPageCount robots-blocked</div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="operator-landing-grid">
            <section class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Quality Summary</p>
                        <h2>Current quality lens</h2>
                    </div>
                    <a href="@Model.QualityUrl" class="btn btn-outline-dark btn-sm">Review quality</a>
                </div>

                <div class="operator-summary-grid compact">
                    @foreach (var summaryCard in Model.QualitySummaryCards)
                    {
                        <partial name="_OperatorSummaryCard" model="summaryCard" />
                    }
                </div>

                @if (Model.SelectedCategory is null)
                {
                    <div class="empty-panel mt-3">
                        <p class="empty-state">No primary category detail is available yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap mt-3">
                        <table class="table dashboard-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Attribute</th>
                                    <th>Type</th>
                                    <th>Unit</th>
                                    <th>Required</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var schemaField in Model.SelectedCategory.Schema.Attributes.Take(6))
                            {
                                <tr>
                                    <td>
                                        <strong>@schemaField.DisplayName</strong>
                                        <div class="subtle-copy mono">@schemaField.Key</div>
                                    </td>
                                    <td>@schemaField.ValueType</td>
                                    <td>@(schemaField.Unit ?? "-")</td>
                                    <td>@(schemaField.IsRequired ? "Required" : "Optional")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Source Health Summary</p>
                        <h2>Registry posture for the current scope</h2>
                    </div>
                    <a href="@Model.SourcesUrl" class="btn btn-outline-dark btn-sm">Manage sources</a>
                </div>

                <div class="operator-summary-grid compact">
                    @foreach (var summaryCard in Model.SourceHealthCards)
                    {
                        <partial name="_OperatorSummaryCard" model="summaryCard" />
                    }
                </div>

                @if (Model.CategorySources.Count == 0)
                {
                    <div class="empty-panel mt-3">
                        <p class="empty-state">No managed sources currently match the active category context.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap mt-3">
                        <table class="table dashboard-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Source</th>
                                    <th>Enabled</th>
                                    <th>Readiness</th>
                                    <th>Health</th>
                                    <th>Last activity</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var source in Model.CategorySources.Take(6))
                            {
                                <tr>
                                    <td>
                                        <strong>@source.DisplayName</strong>
                                        <div class="subtle-copy mono">@source.SourceId</div>
                                        <div class="subtle-copy">@source.ThrottlingPolicy.RequestsPerMinute rpm, @(source.ThrottlingPolicy.RespectRobotsTxt ? "robots respected" : "robots ignored")</div>
                                    </td>
                                    <td><partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetEnabledBadge(source.IsEnabled)" /></td>
                                    <td>
                                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetReadinessBadge(source.Readiness)" />
                                        <div class="subtle-copy mt-2">@source.Readiness.Summary</div>
                                    </td>
                                    <td>
                                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetHealthBadge(source.Health)" />
                                        <div class="subtle-copy mt-2">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatHealthSummary(source.Health)</div>
                                    </td>
                                    <td>
                                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetLastActivityBadge(source.LastActivity)" />
                                        <div class="subtle-copy mt-2">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatLastActivity(source.LastActivity)</div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}