@page
@model ProductNormaliser.Web.Pages.CrawlJobs.IndexModel
@{
    ViewData["Title"] = "Crawl Jobs";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="notice error" role="alert"></div>

    <div class="overview-grid">
        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Launch Crawl</p>
                    <h2>Create a targeted job</h2>
                </div>
            </div>

            <form method="post" asp-page-handler="Launch" class="source-form">
                <input asp-for="Launch.RequestType" type="hidden" value="category" />

                <div class="empty-panel">
                    <p class="empty-state">Launch a category-targeted crawl from the dashboard. Category selection is required, source filtering is optional, and the newly created job will open immediately after submission.</p>
                </div>

                <div>
                    <partial name="_CategorySelector" model="Model.CategorySelector" />
                    <span asp-validation-for="Launch.SelectedCategoryKeys" class="text-danger small"></span>
                </div>

                <div>
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Source Filter</p>
                            <h2>Optionally limit the crawl to selected sources</h2>
                        </div>
                    </div>

                    @if (Model.Sources.Count == 0)
                    {
                        <div class="empty-panel">
                            <p class="empty-state">No sources are registered yet. Launching without a source filter will use every crawlable source for the selected categories.</p>
                        </div>
                    }
                    else
                    {
                        <p class="subtle-copy">Leave this empty to crawl every supported source for the selected categories.</p>
                        <div class="check-grid">
                        @foreach (var source in Model.Sources)
                        {
                            <label class="check-card @(!source.IsEnabled ? "disabled" : string.Empty)" data-source-card>
                                <input type="checkbox"
                                       name="Launch.SelectedSourceIds"
                                       value="@source.SourceId"
                                       checked="@Model.Launch.SelectedSourceIds.Contains(source.SourceId)"
                                       data-source-checkbox
                                       data-supported-categories="@string.Join(',', source.SupportedCategoryKeys)"
                                       data-source-enabled="@source.IsEnabled.ToString().ToLowerInvariant()"
                                       disabled="@(!source.IsEnabled)" />
                                <span>
                                    <strong>@source.DisplayName</strong>
                                    <span class="subtle-copy d-block">@((source.SupportedCategoryKeys.Count == 0 ? "No category metadata" : string.Join(", ", source.SupportedCategoryKeys)))</span>
                                </span>
                            </label>
                        }
                        </div>
                    }
                    <span asp-validation-for="Launch.SelectedSourceIds" class="text-danger small"></span>
                </div>

                <div class="empty-panel">
                    <p class="eyebrow">Recrawl Mode</p>
                    <p class="empty-state">The current Admin API does not expose a separate recrawl mode for category launches, so this panel submits standard category jobs with optional source filtering only.</p>
                </div>

                <div class="actions-bar">
                    <button type="submit" class="btn btn-dark" data-category-launch disabled="@(!Model.CategorySelector.HasSelection)">Launch crawl</button>
                </div>
            </form>
        </section>

        <section class="panel panel-muted">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Visible Jobs</p>
                    <h2>Progress overview</h2>
                </div>
            </div>

            <div class="metric-strip">
                <article>
                    <span>Active jobs</span>
                    <strong>@Model.ActiveJobs.Count</strong>
                </article>
                <article>
                    <span>Completed jobs</span>
                    <strong>@Model.CompletedJobs.Count</strong>
                </article>
                <article>
                    <span>Failed jobs</span>
                    <strong>@Model.FailedJobs.Count</strong>
                </article>
                <article>
                    <span>Visible jobs</span>
                    <strong>@Model.Jobs.Items.Count</strong>
                </article>
            </div>

            <p class="subtle-copy">The list view groups crawl jobs by progress state so operators can separate active work from successful and failed runs at a glance.</p>
        </section>
    </div>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Active Jobs</p>
                <h2>Currently progressing or awaiting cancellation</h2>
            </div>
        </div>

        @if (Model.ActiveJobs.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No active crawl jobs are currently running.</p>
            </div>
        }
        else
        {
            <div class="job-card-grid">
            @foreach (var job in Model.ActiveJobs)
            {
                <article class="job-card">
                    <div class="job-card-header">
                        <div>
                            <a class="mono" asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId">@job.JobId</a>
                            <div class="subtle-copy">@ProductNormaliser.Web.Models.CrawlJobPresentation.GetScopeSummary(job)</div>
                        </div>
                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.CrawlJobPresentation.GetStatusBadge(job.Status)" />
                    </div>

                    <div class="progress-shell">
                        <div class="progress-bar-shell">
                            <div class="progress-bar-fill" style="width: @ProductNormaliser.Web.Models.CrawlJobPresentation.GetProgressPercent(job)%"></div>
                        </div>
                        <div class="subtle-copy">@job.ProcessedTargets / @job.TotalTargets processed</div>
                    </div>

                    <dl class="job-meta-grid">
                        <div><dt>Success</dt><dd>@job.SuccessCount</dd></div>
                        <div><dt>Failed</dt><dd>@job.FailedCount</dd></div>
                        <div><dt>Skipped</dt><dd>@job.SkippedCount</dd></div>
                        <div><dt>Updated</dt><dd>@job.LastUpdatedAt.ToString("u")</dd></div>
                    </dl>

                    <div class="job-card-actions">
                        <a asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId" class="btn btn-outline-dark">View details</a>
                        <form method="post" asp-page-handler="Cancel" class="inline-form">
                            <input type="hidden" name="jobId" value="@job.JobId" />
                            <button type="submit" class="btn btn-outline-danger">Stop job</button>
                        </form>
                    </div>
                </article>
            }
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Completed Jobs</p>
                <h2>Finished successfully</h2>
            </div>
        </div>

        @if (Model.CompletedJobs.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No completed crawl jobs are visible yet.</p>
            </div>
        }
        else
        {
            <div class="job-card-grid">
            @foreach (var job in Model.CompletedJobs)
            {
                <article class="job-card">
                    <div class="job-card-header">
                        <div>
                            <a class="mono" asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId">@job.JobId</a>
                            <div class="subtle-copy">@ProductNormaliser.Web.Models.CrawlJobPresentation.GetScopeSummary(job)</div>
                        </div>
                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.CrawlJobPresentation.GetStatusBadge(job.Status)" />
                    </div>
                    <dl class="job-meta-grid compact">
                        <div><dt>Targets</dt><dd>@job.TotalTargets</dd></div>
                        <div><dt>Success</dt><dd>@job.SuccessCount</dd></div>
                        <div><dt>Skipped</dt><dd>@job.SkippedCount</dd></div>
                        <div><dt>Updated</dt><dd>@job.LastUpdatedAt.ToString("u")</dd></div>
                    </dl>
                    <div class="job-card-actions">
                        <a asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId" class="btn btn-outline-dark">View details</a>
                    </div>
                </article>
            }
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Failed Jobs</p>
                <h2>Runs that need attention</h2>
            </div>
        </div>

        @if (Model.FailedJobs.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No failed or cancelled crawl jobs are visible right now.</p>
            </div>
        }
        else
        {
            <div class="job-card-grid">
            @foreach (var job in Model.FailedJobs)
            {
                <article class="job-card attention">
                    <div class="job-card-header">
                        <div>
                            <a class="mono" asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId">@job.JobId</a>
                            <div class="subtle-copy">@ProductNormaliser.Web.Models.CrawlJobPresentation.GetScopeSummary(job)</div>
                        </div>
                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.CrawlJobPresentation.GetStatusBadge(job.Status)" />
                    </div>
                    <dl class="job-meta-grid compact">
                        <div><dt>Processed</dt><dd>@job.ProcessedTargets</dd></div>
                        <div><dt>Failed</dt><dd>@job.FailedCount</dd></div>
                        <div><dt>Cancelled</dt><dd>@job.CancelledCount</dd></div>
                        <div><dt>Updated</dt><dd>@job.LastUpdatedAt.ToString("u")</dd></div>
                    </dl>
                    <div class="job-card-actions">
                        <a asp-page="/CrawlJobs/Details" asp-route-jobId="@job.JobId" class="btn btn-outline-dark">View details</a>
                    </div>
                </article>
            }
            </div>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (Model.ShouldAutoRefresh)
    {
        <script>
            window.setTimeout(function () {
                window.location.reload();
            }, 10000);
        </script>
    }
}