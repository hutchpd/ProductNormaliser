@using ProductNormaliser.Web.Models
@inject ProductNormaliser.Web.Services.IProductNormaliserAdminApiClient AdminApiClient
@{
    CategoryContextState? shellCategoryContext = null;

    if (User.Identity?.IsAuthenticated == true)
    {
        try
        {
            var shellCategories = InteractiveCategoryFilter.Apply(await AdminApiClient.GetCategoriesAsync());
            shellCategoryContext = CategoryContextStateFactory.Resolve(
                shellCategories,
                Context.Request.Query["category"].ToString(),
                Context.Request.Query["selectedCategory"].Where(static value => !string.IsNullOrWhiteSpace(value)).Select(static value => value!).ToArray(),
                Context.Request.Cookies[CategoryContextState.CookieName]);
            CategoryContextStateFactory.Persist(Context.Response, shellCategoryContext);
        }
        catch
        {
            shellCategoryContext = null;
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProductNormaliser</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProductNormaliser.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="app-shell-header mb-4">
            <div class="container-xl app-shell-header-inner">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#appNavigationDrawer" aria-controls="appNavigationDrawer" aria-label="Open navigation menu">
                        <span aria-hidden="true">☰</span>
                        <span>Menu</span>
                    </button>
                }
                <a class="navbar-brand" asp-area="" asp-page="/Index">ProductNormaliser</a>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="offcanvas offcanvas-start app-drawer" tabindex="-1" id="appNavigationDrawer" aria-labelledby="appNavigationDrawerLabel">
                <div class="offcanvas-header app-drawer-header">
                    <div>
                        <span class="drawer-eyebrow">Navigation</span>
                        <h2 class="offcanvas-title" id="appNavigationDrawerLabel">ProductNormaliser</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body app-drawer-body">
                    <ul class="navbar-nav app-drawer-nav">
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Categories/Index">Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/CrawlJobs/Index">Crawl Jobs</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Quality/Index">Quality</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Products/Index">Products</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Sources/Index">Sources</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Sources/Intelligence">Source Intelligence</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-nav-drawer-dismiss="true" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="app-drawer-footer">
                        <span class="subtle-copy">Signed in as @User.Identity.Name</span>
                        <form method="post" asp-page="/Login" asp-page-handler="Logout" class="inline-form">
                            <button type="submit" class="btn btn-outline-dark btn-sm">Sign out</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </header>
    <div class="container-xl">
        @if (shellCategoryContext is not null)
        {
            <partial name="_CategoryContextShell" model="shellCategoryContext" />
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-shell text-muted">
        <div class="container-xl footer-inner">
            <span>ProductNormaliser dashboard for category-aware crawl intelligence</span>
            <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
