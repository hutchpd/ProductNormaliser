@page
@model ProductNormaliser.Web.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Detail";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div class="panel product-jump-nav-panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Navigation</p>
                <h2>Jump to section</h2>
            </div>
                <a href="@Model.BackToExplorerUrl" class="btn btn-outline-secondary">Back to explorer</a>
        </div>

        <nav class="product-jump-nav">
            <a href="#summary">Summary</a>
            <a href="#key-attributes">Key attributes</a>
            <a href="#investigation">Investigation</a>
            <a href="#comparison">Source comparison</a>
            <a href="#evidence">Evidence</a>
            <a href="#conflicts">Conflicts</a>
            <a href="#timeline">Timeline</a>
            <a href="#attribute-history">Attribute history</a>
        </nav>
    </div>

    @if (Model.Product is not null)
    {
        <partial name="_ProductSummarySection" model="Model" />
        <partial name="_ProductKeyAttributesSection" model="Model" />
        <partial name="_ProductInvestigationSection" model="Model" />
        <partial name="_ProductComparisonSection" model="Model" />
        <partial name="_ProductEvidenceSection" model="Model" />
        <partial name="_ProductConflictSection" model="Model" />
        <partial name="_ProductTimelineSection" model="Model" />
    }
</section>
