@page
@model ProductNormaliser.Web.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Detail";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div class="panel product-jump-nav-panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Navigation</p>
                <h2>Jump to section</h2>
            </div>
            <a asp-page="/Products/Index"
               asp-route-category="@Model.ReturnCategory"
               asp-route-search="@Model.ReturnSearch"
               asp-route-page="@Model.ReturnPage"
               asp-route-minSourceCount="@Model.ReturnMinSourceCount"
               asp-route-freshness="@Model.ReturnFreshness"
               asp-route-conflictStatus="@Model.ReturnConflictStatus"
               asp-route-completeness="@Model.ReturnCompletenessStatus"
               class="btn btn-outline-secondary">Back to explorer</a>
        </div>

        <nav class="product-jump-nav">
            <a href="#summary">Summary</a>
            <a href="#key-attributes">Key attributes</a>
            <a href="#comparison">Source comparison</a>
            <a href="#evidence">Evidence</a>
            <a href="#conflicts">Conflicts</a>
            <a href="#timeline">Timeline</a>
        </nav>
    </div>

    @if (Model.Product is not null)
    {
        <section id="summary" class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Canonical Summary</p>
                    <h2>@Model.Product.DisplayName</h2>
                </div>
                <div class="chip-row">
                    <span class="status-pill @Model.FreshnessBadge.Tone">@Model.FreshnessBadge.Text</span>
                    <span class="status-pill @Model.CompletenessBadge.Tone">@Model.CompletenessBadge.Text</span>
                    <span class="status-pill @Model.ConflictBadge.Tone">@Model.ConflictBadge.Text</span>
                </div>
            </div>

            <dl class="detail-grid product-summary-grid">
                <div>
                    <dt>Category</dt>
                    <dd>@Model.Product.CategoryKey</dd>
                </div>
                <div>
                    <dt>Source count</dt>
                    <dd>@Model.Product.SourceCount</dd>
                </div>
                <div>
                    <dt>Evidence count</dt>
                    <dd>@Model.Product.EvidenceCount</dd>
                </div>
                <div>
                    <dt>Completeness</dt>
                    <dd>@ProductNormaliser.Web.Models.ProductExplorerPresentation.FormatPercent(Model.Product.CompletenessScore)</dd>
                </div>
                <div>
                    <dt>Created</dt>
                    <dd>@Model.Product.CreatedUtc.ToString("u")</dd>
                </div>
                <div>
                    <dt>Updated</dt>
                    <dd>@Model.Product.UpdatedUtc.ToString("u")</dd>
                </div>
            </dl>
        </section>

        <section id="key-attributes" class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Key Attributes</p>
                    <h2>Most useful canonical fields</h2>
                </div>
            </div>

            @if (Model.Product.KeyAttributes.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No key attributes are available for this product.</p>
                </div>
            }
            else
            {
                <div class="product-key-attribute-list detail">
                    @foreach (var keyAttribute in Model.Product.KeyAttributes)
                    {
                        <div class="product-key-attribute @(keyAttribute.HasConflict ? "attention" : string.Empty)">
                            <dt>@keyAttribute.DisplayName</dt>
                            <dd>@keyAttribute.Value</dd>
                        </div>
                    }
                </div>
            }
        </section>

        <section id="comparison" class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Side By Side</p>
                    <h2>Source comparison</h2>
                </div>
            </div>

            @if (Model.SourceComparisonRows.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">This product does not have comparable attribute evidence yet.</p>
                </div>
            }
            else
            {
                <div class="comparison-table-wrap">
                    <table class="comparison-table">
                        <thead>
                            <tr>
                                <th class="sticky-col">Attribute</th>
                                <th class="canonical-col">Canonical</th>
                                @foreach (var source in Model.SourceComparisonColumns)
                                {
                                    <th>
                                        <div class="comparison-source-heading">
                                            <strong>@source.SourceName</strong>
                                            <span>@source.Title</span>
                                            <span>@(source.ModelNumber ?? source.Gtin ?? "No model metadata")</span>
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.SourceComparisonRows)
                            {
                                <tr class="@(row.HasConflict ? "comparison-row-conflict" : string.Empty)">
                                    <th class="sticky-col" scope="row">
                                        <div class="comparison-attribute">
                                            <span class="mono">@row.AttributeKey</span>
                                            <span class="subtle-copy">@row.EvidenceCount evidence item@(row.EvidenceCount == 1 ? string.Empty : "s")</span>
                                        </div>
                                    </th>
                                    <td class="comparison-canonical @(row.HasConflict ? "attention" : string.Empty)">
                                        <strong>@row.CanonicalValue</strong>
                                        <span class="status-pill @(row.HasConflict ? "warning" : "completed")">@(row.HasConflict ? "Conflict" : "Canonical")</span>
                                    </td>
                                    @foreach (var cell in row.Cells)
                                    {
                                        <td class="@(cell.HasClaim ? (cell.HasDisagreement ? "comparison-cell disagreement" : cell.MatchesCanonical ? "comparison-cell canonical-match" : "comparison-cell claimed") : "comparison-cell missing")">
                                            @if (!cell.HasClaim)
                                            {
                                                <span class="subtle-copy">No claim</span>
                                            }
                                            else
                                            {
                                                <div class="claim-stack">
                                                    @foreach (var claim in cell.Claims)
                                                    {
                                                        <div class="claim-card @(claim.MatchesCanonical ? "canonical" : "disagreement")">
                                                            <strong>@claim.DisplayValue</strong>
                                                            <span class="subtle-copy">@claim.SourceAttributeKey</span>
                                                            @if (!string.IsNullOrWhiteSpace(claim.SelectorOrPath))
                                                            {
                                                                <span class="subtle-copy">@claim.SelectorOrPath</span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section id="evidence" class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Evidence Inspector</p>
                    <h2>Attribute evidence</h2>
                </div>
            </div>

            @if (Model.EvidenceInspectorRows.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No attribute evidence is available for the selected product.</p>
                </div>
            }
            else
            {
                <div class="evidence-stack">
                    @foreach (var row in Model.EvidenceInspectorRows)
                    {
                        <details class="evidence-item @(row.HasConflict ? "attention" : string.Empty)">
                            <summary>
                                <div>
                                    <strong class="mono">@row.AttributeKey</strong>
                                    <span class="subtle-copy">Canonical: @row.CanonicalValue</span>
                                </div>
                                <div class="chip-row">
                                    <span class="status-pill @(row.HasConflict ? "warning" : "completed")">@(row.HasConflict ? "Conflict" : "Aligned")</span>
                                    <span class="status-pill neutral">@row.Evidence.Count evidence item@(row.Evidence.Count == 1 ? string.Empty : "s")</span>
                                </div>
                            </summary>

                            @if (row.Evidence.Count == 0)
                            {
                                <div class="empty-panel">
                                    <p class="empty-state">No evidence items were returned for this attribute.</p>
                                </div>
                            }
                            else
                            {
                                <div class="evidence-card-grid">
                                    @foreach (var evidence in row.Evidence)
                                    {
                                        <article class="evidence-card @(evidence.MatchesCanonical ? "canonical" : "disagreement")">
                                            <div class="evidence-card-header">
                                                <strong>@evidence.SourceName</strong>
                                                <span class="status-pill @(evidence.MatchesCanonical ? "completed" : "warning")">@(evidence.MatchesCanonical ? "Matches canonical" : "Differs")</span>
                                            </div>
                                            <div class="evidence-meta-grid">
                                                <div>
                                                    <dt>Claimed value</dt>
                                                    <dd>@evidence.DisplayValue</dd>
                                                </div>
                                                <div>
                                                    <dt>Source product</dt>
                                                    <dd class="mono">@evidence.SourceProductId</dd>
                                                </div>
                                                <div>
                                                    <dt>Source field</dt>
                                                    <dd class="mono">@evidence.SourceAttributeKey</dd>
                                                </div>
                                                <div>
                                                    <dt>Observed</dt>
                                                    <dd>@evidence.ObservedUtc.ToString("u")</dd>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(evidence.SelectorOrPath) || !string.IsNullOrWhiteSpace(evidence.SourceUrl))
                                            {
                                                <div class="evidence-footnotes">
                                                    @if (!string.IsNullOrWhiteSpace(evidence.SelectorOrPath))
                                                    {
                                                        <p class="subtle-copy"><span class="mono">@evidence.SelectorOrPath</span></p>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(evidence.SourceUrl))
                                                    {
                                                        <p><a href="@evidence.SourceUrl" target="_blank" rel="noreferrer">Open source page</a></p>
                                                    }
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            }
                        </details>
                    }
                </div>
            }
        </section>

        <section id="conflicts" class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Disagreement</p>
                    <h2>Conflict panel</h2>
                </div>
            </div>

            @if (Model.ConflictRows.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No disagreement is recorded for the selected product.</p>
                </div>
            }
            else
            {
                <div class="conflict-stack">
                    @foreach (var conflict in Model.ConflictRows)
                    {
                        <article class="conflict-card">
                            <div class="conflict-card-header">
                                <div>
                                    <h4 class="mono">@conflict.AttributeKey</h4>
                                    <p class="subtle-copy">Canonical value: <strong>@conflict.CanonicalValue</strong></p>
                                </div>
                                <span class="status-pill warning">@conflict.Groups.Count distinct claim@(conflict.Groups.Count == 1 ? string.Empty : "s")</span>
                            </div>

                            <div class="conflict-group-list">
                                @foreach (var group in conflict.Groups)
                                {
                                    <div class="conflict-group @(group.IsCanonical ? "canonical" : "disagreement")">
                                        <strong>@group.DisplayValue</strong>
                                        <span>@string.Join(", ", group.Sources)</span>
                                        @if (group.IsCanonical)
                                        {
                                            <span class="status-pill completed">Canonical</span>
                                        }
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section id="timeline" class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Timeline</p>
                    <h2>Product history</h2>
                </div>
            </div>

            @if (Model.Timeline.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No history events are recorded for this product yet.</p>
                </div>
            }
            else
            {
                <ol class="timeline-list">
                    @foreach (var change in Model.Timeline)
                    {
                        <li class="timeline-item">
                            <div class="timeline-marker"></div>
                            <article class="timeline-card">
                                <div class="timeline-card-header">
                                    <div>
                                        <strong class="mono">@change.AttributeKey</strong>
                                        <p class="subtle-copy">@change.SourceName</p>
                                    </div>
                                    <time>@change.TimestampUtc.ToString("u")</time>
                                </div>
                                <p>@change.ChangeSummary</p>
                                <div class="timeline-value-grid">
                                    <div>
                                        <dt>Old</dt>
                                        <dd>@change.OldValue</dd>
                                    </div>
                                    <div>
                                        <dt>New</dt>
                                        <dd>@change.NewValue</dd>
                                    </div>
                                </div>
                            </article>
                        </li>
                    }
                </ol>
            }
        </section>
    }
</section>
