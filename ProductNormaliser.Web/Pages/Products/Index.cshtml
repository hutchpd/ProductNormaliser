@page
@model ProductNormaliser.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Explorer Filters</p>
                <h2>Find products by quality signals</h2>
                <p class="subtle-copy">Mix search with category, source coverage, freshness, disagreement, and completeness to surface the products you actually need to inspect.</p>
            </div>
        </div>

        <form method="get" class="product-filter-grid">
            <div>
                <label asp-for="Search" class="form-label">Search</label>
                <input asp-for="Search" class="form-control" placeholder="Display name, brand, model, GTIN, or id" />
            </div>
            <div>
                <label asp-for="CategoryKey" class="form-label">Category</label>
                <select asp-for="CategoryKey" class="form-select">
                    <option value="">All categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryKey">@category.DisplayName</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="MinSourceCount" class="form-label">Source count</label>
                <select asp-for="MinSourceCount" class="form-select">
                    <option value="">Any source count</option>
                    <option value="1">1+ sources</option>
                    <option value="2">2+ sources</option>
                    <option value="3">3+ sources</option>
                    <option value="5">5+ sources</option>
                </select>
            </div>
            <div>
                <label asp-for="Freshness" class="form-label">Freshness</label>
                <select asp-for="Freshness" class="form-select">
                    <option value="">Any freshness</option>
                    <option value="fresh">Fresh</option>
                    <option value="aging">Aging</option>
                    <option value="stale">Stale</option>
                </select>
            </div>
            <div>
                <label asp-for="ConflictStatus" class="form-label">Disagreement</label>
                <select asp-for="ConflictStatus" class="form-select">
                    <option value="">Any conflict state</option>
                    <option value="with_conflicts">With conflicts</option>
                    <option value="without_conflicts">Without conflicts</option>
                </select>
            </div>
            <div>
                <label asp-for="CompletenessStatus" class="form-label">Completeness</label>
                <select asp-for="CompletenessStatus" class="form-select">
                    <option value="">Any completeness</option>
                    <option value="complete">Complete</option>
                    <option value="partial">Partial</option>
                    <option value="sparse">Sparse</option>
                </select>
            </div>
            <div>
                <label asp-for="Sort" class="form-label">Sort</label>
                <select asp-for="Sort" class="form-select">
                    <option value="">Recently updated</option>
                    <option value="stale">Stalest first</option>
                    <option value="completeness_asc">Lowest completeness first</option>
                    <option value="conflicts_desc">Most conflicts first</option>
                </select>
            </div>
            <div class="actions-bar product-filter-actions">
                <button type="submit" class="btn btn-dark">Apply Filters</button>
                <a asp-page="/Products/Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </section>

    <section class="panel panel-muted">
        <div class="metric-strip product-analysis-strip">
            <article>
                <span>Products with conflicts</span>
                <strong>@Model.ProductsWithConflicts</strong>
            </article>
            <article>
                <span>Stale products in view</span>
                <strong>@Model.StaleProducts</strong>
            </article>
            <article>
                <span>Average completeness</span>
                <strong>@ProductNormaliser.Web.Models.ProductExplorerPresentation.FormatPercent(Model.AverageCompleteness)</strong>
            </article>
            <article>
                <span>Current page</span>
                <strong>@Model.Products.Page / @Math.Max(Model.Products.TotalPages, 1)</strong>
            </article>
        </div>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Results</p>
                <h2>Analysis-ready product explorer</h2>
            </div>
        </div>

        @if (Model.Products.Items.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No products match the current filter combination.</p>
            </div>
        }
        else
        {
            <div class="product-result-grid">
                @foreach (var product in Model.Products.Items)
                {
                    var freshnessBadge = Model.GetFreshnessBadge(product);
                    var completenessBadge = Model.GetCompletenessBadge(product);
                    var conflictBadge = Model.GetConflictBadge(product);

                    <article class="product-result-card @(product.HasConflict ? "attention" : string.Empty)">
                        <div class="product-result-header">
                            <div>
                                <h3>
                                    <a href="@Model.GetDetailUrl(product)">@product.DisplayName</a>
                                </h3>
                                <p class="subtle-copy mono">@product.Id</p>
                                <p class="subtle-copy">@product.Brand @(string.IsNullOrWhiteSpace(product.ModelNumber) ? string.Empty : $"/ {product.ModelNumber}")</p>
                            </div>
                            <div class="chip-row product-result-badges">
                                <span class="status-pill @freshnessBadge.Tone">@freshnessBadge.Text</span>
                                <span class="status-pill @completenessBadge.Tone">@completenessBadge.Text</span>
                                <span class="status-pill @conflictBadge.Tone">@conflictBadge.Text</span>
                            </div>
                        </div>

                        <dl class="job-meta-grid compact product-result-metrics">
                            <div>
                                <dt>Category</dt>
                                <dd>@product.CategoryKey</dd>
                            </div>
                            <div>
                                <dt>Sources</dt>
                                <dd>@product.SourceCount</dd>
                            </div>
                            <div>
                                <dt>Evidence</dt>
                                <dd>@product.EvidenceCount</dd>
                            </div>
                            <div>
                                <dt>Updated</dt>
                                <dd>@product.UpdatedUtc.ToString("u")</dd>
                            </div>
                        </dl>

                        <div class="product-key-attribute-list">
                            @if (product.KeyAttributes.Count == 0)
                            {
                                <p class="empty-state">No key attributes were projected for this product.</p>
                            }
                            else
                            {
                                @foreach (var keyAttribute in product.KeyAttributes)
                                {
                                    <div class="product-key-attribute @(keyAttribute.HasConflict ? "attention" : string.Empty)">
                                        <dt>@keyAttribute.DisplayName</dt>
                                        <dd>@keyAttribute.Value</dd>
                                    </div>
                                }
                            }
                        </div>
                    </article>
                }
            </div>

            <partial name="_Pager" model="Model.Pagination" />
        }
    </section>
</section>
