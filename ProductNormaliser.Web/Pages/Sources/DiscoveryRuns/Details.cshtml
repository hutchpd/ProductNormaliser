@page
@model ProductNormaliser.Web.Pages.Sources.DiscoveryRuns.DetailsModel
@{
    ViewData["Title"] = "Discovery Run Details";
}

<section class="dashboard-shell">
    @if (Model.Run is null)
    {
        <partial name="_PageHero" model="Model.Hero" />
    }
    else
    {
        <div class="hero-panel discovery-run-hero">
            <div>
                <p class="eyebrow">Discovery Run</p>
                <div class="run-id-scroll" title="@Model.Run.RunId">
                    <h1 class="mono">@Model.Run.RunId</h1>
                </div>
                <p class="hero-copy">This page follows the persisted background discovery run, including stage progress, serial local verification throughput, candidate decisions, and the latest run activity.</p>
            </div>

            <div class="hero-metrics">
                <article>
                    <span>Stage</span>
                    <strong>@ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStageLabel(Model.Run.CurrentStage)</strong>
                </article>
                <article>
                    <span>Progress</span>
                    <strong>@Model.ProgressPercent%</strong>
                </article>
                <article>
                    <span>Suggested</span>
                    <strong>@Model.Run.SuggestedCandidateCount</strong>
                </article>
                <article>
                    <span>Published</span>
                    <strong>@Model.Run.PublishedCandidateCount</strong>
                </article>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    @if (Model.Run is null)
    {
        <section class="panel">
            <div class="empty-panel">
                <p class="empty-state">No discovery run details are available yet.</p>
                <div class="actions-bar inline-actions">
                    <a href="/Sources/Index" class="btn btn-outline-dark">Back to sources</a>
                </div>
            </div>
        </section>
    }
    else
    {
        @if (Model.ShouldAutoRefresh)
        {
            <div class="notice success">This discovery run is active. The page refreshes every 5 seconds while worker progress changes.</div>
        }

        <div class="split-layout">
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Overall Status</p>
                        <div class="run-id-scroll compact" title="@Model.Run.RunId">
                            <h2 class="mono">@Model.Run.RunId</h2>
                        </div>
                    </div>
                    <partial name="_StatusBadge" model="Model.StatusBadge" />
                </div>

                <div class="progress-shell">
                    <div class="progress-bar-shell">
                        <div class="progress-bar-fill" style="width: @Model.ProgressPercent%"></div>
                    </div>
                    <div class="subtle-copy">@ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStageLabel(Model.Run.CurrentStage) stage, @Model.Run.ProbeCompletedCount of @Math.Max(Model.Run.CollapsedCandidateCount, Model.Run.MaxCandidates) candidate slots processed</div>
                </div>

                <div class="chip-row mt-3">
                    <span class="chip">Stage: @ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStageLabel(Model.Run.CurrentStage)</span>
                    <span class="chip">LLM queue depth: @Model.Run.LlmQueueDepth</span>
                    <span class="chip">LLM completed: @Model.Run.LlmCompletedCount</span>
                    @if (Model.Run.LlmAverageElapsedMs is > 0)
                    {
                        <span class="chip">LLM avg: @Model.Run.LlmAverageElapsedMs.Value ms</span>
                    }
                </div>

                <dl class="detail-grid mt-3">
                    <div><dt>Requested categories</dt><dd>@string.Join(", ", Model.Run.RequestedCategoryKeys)</dd></div>
                    <div><dt>Market / locale</dt><dd>@(string.IsNullOrWhiteSpace(Model.Run.Market) ? "Any market" : Model.Run.Market) / @(string.IsNullOrWhiteSpace(Model.Run.Locale) ? "Any locale" : Model.Run.Locale)</dd></div>
                    <div><dt>Automation mode</dt><dd>@Model.Run.AutomationMode</dd></div>
                    <div><dt>Search results</dt><dd>@Model.Run.SearchResultCount</dd></div>
                    <div><dt>Collapsed candidates</dt><dd>@Model.Run.CollapsedCandidateCount</dd></div>
                    <div><dt>Suggested</dt><dd>@Model.Run.SuggestedCandidateCount</dd></div>
                    <div><dt>Auto-accepted</dt><dd>@Model.Run.AutoAcceptedCandidateCount</dd></div>
                    <div><dt>Published</dt><dd>@Model.Run.PublishedCandidateCount</dd></div>
                    <div><dt>LLM status</dt><dd>@Model.Run.LlmStatus</dd></div>
                    <div><dt>Created</dt><dd>@Model.Run.CreatedUtc.ToString("u")</dd></div>
                    <div><dt>Started</dt><dd>@(Model.Run.StartedUtc?.ToString("u") ?? "Not started")</dd></div>
                    <div><dt>Last updated</dt><dd>@Model.Run.UpdatedUtc.ToString("u")</dd></div>
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Run.StatusMessage))
                {
                    <div class="notice info mt-3">@Model.Run.StatusMessage</div>
                }

                @foreach (var diagnostic in Model.Run.Diagnostics)
                {
                    <div class="@Model.GetDiscoveryDiagnosticNoticeClass(diagnostic)">
                        <strong>@diagnostic.Title</strong>
                        <div>@diagnostic.Message</div>
                    </div>
                }

                <div class="actions-bar inline-actions">
                    <a href="/Sources/Index" class="btn btn-outline-dark">Back to sources</a>
                    @if (ProductNormaliser.Web.Models.DiscoveryRunPresentation.CanPause(Model.Run.Status))
                    {
                        <form method="post" asp-page-handler="Pause" class="inline-form">
                            <input type="hidden" asp-for="RunId" />
                            <button type="submit" class="btn btn-outline-dark">Pause run</button>
                        </form>
                    }
                    @if (ProductNormaliser.Web.Models.DiscoveryRunPresentation.CanResume(Model.Run.Status))
                    {
                        <form method="post" asp-page-handler="Resume" class="inline-form">
                            <input type="hidden" asp-for="RunId" />
                            <button type="submit" class="btn btn-outline-dark">Resume run</button>
                        </form>
                    }
                    @if (ProductNormaliser.Web.Models.DiscoveryRunPresentation.CanStop(Model.Run.Status))
                    {
                        <form method="post" asp-page-handler="Stop" class="inline-form">
                            <input type="hidden" asp-for="RunId" />
                            <button type="submit" class="btn btn-outline-danger">Stop run</button>
                        </form>
                    }
                </div>
            </section>

            <aside class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">LLM Throughput</p>
                        <h2>Serial verification lane</h2>
                    </div>
                </div>

                <div class="detail-grid">
                    <div><dt>Queue depth</dt><dd>@Model.Run.LlmQueueDepth</dd></div>
                    <div><dt>Completed</dt><dd>@Model.Run.LlmCompletedCount</dd></div>
                    <div><dt>Total elapsed</dt><dd>@Model.Run.LlmTotalElapsedMs ms</dd></div>
                    <div><dt>Average elapsed</dt><dd>@(Model.Run.LlmAverageElapsedMs?.ToString() ?? "n/a")</dd></div>
                </div>

                <p class="empty-state mt-3">LLM verification intentionally runs serially or at very low concurrency so local inference stays predictable while the operator watches progress.</p>
            </aside>
        </div>

        <section class="panel panel-muted">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Timeouts And Fallbacks</p>
                    <h2>What actually timed out</h2>
                    <p class="subtle-copy">Search timeout means the provider query stage overran its run budget. Probe timeout means the full per-candidate representative-page probe overran. Representative fetch failure means a page was chosen but could not be fetched. LLM timeout only affects representative product-page classification.</p>
                </div>
            </div>

            <div class="detail-grid">
                <div>
                    <dt>Search stage timeouts</dt>
                    <dd>@Model.SearchTimeoutCount run-level timeout(s)</dd>
                </div>
                <div>
                    <dt>Candidate probe timeouts</dt>
                    <dd>@Model.ProbeTimeoutCandidateCount candidate(s)</dd>
                </div>
                <div>
                    <dt>Representative fetch failures</dt>
                    <dd>@Model.RepresentativePageFetchFailureCandidateCount candidate(s)</dd>
                </div>
                <div>
                    <dt>LLM verification timeouts</dt>
                    <dd>@Model.LlmTimeoutCandidateCount candidate(s)</dd>
                </div>
            </div>

            @if (Model.RepresentativePageFetchFailureCandidateCount > 0)
            {
                <p class="subtle-copy mt-3 mb-0">Representative fetch failures include @Model.RepresentativeCategoryFetchFailureCount category page failure(s) and @Model.RepresentativeProductFetchFailureCount product page failure(s).</p>
            }
        </section>

        <div class="split-layout discovery-run-insights-layout">
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Run Activity</p>
                        <h2>Activity log</h2>
                        <p class="subtle-copy">Search scope, diagnostics, and archived-candidate decisions are listed here in reverse chronological order. Snapshot entries use the latest persisted run update when the backend does not persist an exact event time.</p>
                    </div>
                </div>

                @if (Model.ActivityLogEntries.Count == 0)
                {
                    <div class="empty-panel">
                        <p class="empty-state">No run activity is available yet.</p>
                    </div>
                }
                else
                {
                    <div class="activity-log-shell" role="log" aria-live="polite">
                    @foreach (var entry in Model.ActivityLogEntries)
                    {
                        <article class="@Model.GetActivityEntryClass(entry)">
                            <div class="activity-log-meta">
                                <span class="mono">@entry.TimestampUtc.ToString("u")</span>
                                <span>@entry.TimestampKind</span>
                            </div>
                            <strong>@entry.Title</strong>
                            <p>@entry.Message</p>
                            @if (!string.IsNullOrWhiteSpace(entry.Code))
                            {
                                <span class="chip mono">@entry.Code</span>
                            }
                        </article>
                    }
                    </div>
                }
            </section>

            <aside class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Rejected Hosts</p>
                        <h2>Archived and rejected candidates</h2>
                        <p class="subtle-copy">If a persisted candidate was dismissed or archived but you still want to review it, add it back to the active queue here.</p>
                    </div>
                </div>

                @if (Model.ArchivedCandidates.Count == 0)
                {
                    <div class="empty-panel">
                        <p class="empty-state">No archived candidates are available for this run yet.</p>
                    </div>
                }
                else
                {
                    <div class="job-breakdown-grid compact-breakdown-grid">
                    @foreach (var candidate in Model.ArchivedCandidates)
                    {
                        <article>
                            <div class="panel-heading compact-panel-heading">
                                <div>
                                    <strong>@candidate.DisplayName</strong>
                                    <div class="subtle-copy mono">@candidate.Host</div>
                                </div>
                                <span class="badge @Model.GetCandidateStatusTone(candidate)">@candidate.State</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(candidate.ArchiveReason))
                            {
                                <div class="subtle-copy">Archive reason: @candidate.ArchiveReason</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(candidate.StateMessage))
                            {
                                <div class="subtle-copy">@candidate.StateMessage</div>
                            }
                            @if (candidate.ArchivedUtc is not null)
                            {
                                <div class="subtle-copy mono">Archived @candidate.ArchivedUtc.Value.ToString("u")</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(candidate.SupersededByCandidateKey))
                            {
                                <div class="subtle-copy">Superseded by @candidate.SupersededByCandidateKey</div>
                            }
                            @if (Model.GetCandidateReasonSummary(candidate).Count > 0)
                            {
                                <ul class="candidate-reason-list">
                                @foreach (var reason in Model.GetCandidateReasonSummary(candidate))
                                {
                                    <li>@reason</li>
                                }
                                </ul>
                            }
                            @if (Model.CanRestoreCandidate(candidate))
                            {
                                <form method="post" asp-page-handler="RestoreCandidate" class="inline-form mt-2">
                                    <input type="hidden" asp-for="RunId" />
                                    <input type="hidden" name="candidateKey" value="@candidate.CandidateKey" />
                                    <input type="hidden" name="expectedRevision" value="@candidate.Revision" />
                                    <button type="submit" class="btn btn-outline-dark">@Model.GetArchiveActionLabel(candidate)</button>
                                </form>
                            }
                        </article>
                    }
                    </div>
                }
            </aside>
        </div>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Candidates</p>
                    <h2>Suggested and published hosts</h2>
                </div>
            </div>

            @if (Model.ActiveCandidates.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No active candidates are available for this run yet.</p>
                </div>
            }
            else
            {
                <div class="job-breakdown-grid">
                @foreach (var candidate in Model.ActiveCandidates)
                {
                    <article>
                        <div class="panel-heading">
                            <div>
                                <strong>@candidate.DisplayName</strong>
                                <div class="subtle-copy">@candidate.Host</div>
                            </div>
                            <span class="badge @Model.GetCandidateStatusTone(candidate)">@candidate.State</span>
                        </div>
                        <div class="subtle-copy">Confidence @candidate.ConfidenceScore.ToString("0.#"), crawlability @candidate.CrawlabilityScore.ToString("0.#"), extractability @candidate.ExtractabilityScore.ToString("0.#")</div>
                        <div class="subtle-copy">@candidate.RuntimeExtractionMessage</div>
                        @if (!string.IsNullOrWhiteSpace(candidate.StateMessage))
                        {
                            <div class="subtle-copy">@candidate.StateMessage</div>
                        }
                        <div class="actions-bar inline-actions mt-2">
                            @if (Model.CanAcceptCandidate(candidate))
                            {
                                <form method="post" asp-page-handler="AcceptCandidate" class="inline-form">
                                    <input type="hidden" asp-for="RunId" />
                                    <input type="hidden" name="candidateKey" value="@candidate.CandidateKey" />
                                    <input type="hidden" name="expectedRevision" value="@candidate.Revision" />
                                    <button type="submit" class="btn btn-dark">Accept candidate</button>
                                </form>
                            }
                            @if (Model.CanDismissCandidate(candidate))
                            {
                                <form method="post" asp-page-handler="DismissCandidate" class="inline-form">
                                    <input type="hidden" asp-for="RunId" />
                                    <input type="hidden" name="candidateKey" value="@candidate.CandidateKey" />
                                    <input type="hidden" name="expectedRevision" value="@candidate.Revision" />
                                    <button type="submit" class="btn btn-outline-dark">Dismiss</button>
                                </form>
                            }
                        </div>
                    </article>
                }
                </div>
            }
            </section>
        }
</section>

@section Scripts {
    @if (Model.ShouldAutoRefresh)
    {
        <script>
            window.setTimeout(function () {
                window.location.reload();
            }, 5000);
        </script>
    }
}