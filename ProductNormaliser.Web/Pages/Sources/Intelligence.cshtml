@page
@model ProductNormaliser.Web.Pages.Sources.IntelligenceModel
@{
    ViewData["Title"] = "Source Intelligence";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.WorkflowMessage))
    {
        <div class="notice error">@Model.WorkflowMessage</div>
    }

    <section class="panel panel-muted">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Saved Workflows</p>
                <h2>Keep source review queues ready</h2>
                <p class="subtle-copy">Save category, source, and time-window combinations so the same weak-source or high-value review queue is one click away.</p>
            </div>
        </div>

        <form method="post" asp-page-handler="SaveView" class="analytics-filter-grid two-up">
            <input type="hidden" name="CategoryKey" value="@Model.CategoryKey" />
            <input type="hidden" name="SourceName" value="@Model.SourceName" />
            <input type="hidden" name="TimeRangeDays" value="@Model.EffectiveTimeRangeDays" />
            <input type="hidden" name="SavedViewId" value="@Model.SavedViewId" />
            <div>
                <label asp-for="SaveViewName" class="form-label">View name</label>
                <input asp-for="SaveViewName" class="form-control" placeholder="Monitor source drift" />
            </div>
            <div>
                <label asp-for="SaveViewDescription" class="form-label">Description</label>
                <input asp-for="SaveViewDescription" class="form-control" placeholder="Optional context for the next analyst" />
            </div>
            <div class="actions-bar analytics-filter-actions">
                <button type="submit" name="workflowType" value="source_review_queue" class="btn btn-dark">Save source queue</button>
                <button type="submit" name="workflowType" value="selected_categories" class="btn btn-outline-dark">Save category watchlist</button>
            </div>
        </form>

        @if (Model.SavedWorkflows.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No saved source workflows exist yet.</p>
            </div>
        }
        else
        {
            <div class="analytics-card-grid">
                @foreach (var workflow in Model.SavedWorkflows)
                {
                    <article class="analytics-card @(workflow.IsCurrent ? "attention" : string.Empty)">
                        <div class="analytics-card-header">
                            <div>
                                <strong>@workflow.Name</strong>
                                <p class="subtle-copy">@workflow.WorkflowTypeLabel • @workflow.PrimaryCategoryLabel</p>
                            </div>
                            <span class="status-pill @workflow.StatusTone">@workflow.StatusText</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(workflow.Description))
                        {
                            <p class="subtle-copy">@workflow.Description</p>
                        }
                        <p class="subtle-copy">@workflow.Summary</p>
                        <div class="actions-bar analytics-filter-actions">
                            <a href="@workflow.RestoreUrl" class="btn btn-outline-dark btn-sm">Restore</a>
                            <form method="post" asp-page-handler="DeleteView" class="inline-form">
                                <input type="hidden" name="workflowId" value="@workflow.Id" />
                                <input type="hidden" name="CategoryKey" value="@Model.CategoryKey" />
                                <input type="hidden" name="SourceName" value="@Model.SourceName" />
                                <input type="hidden" name="TimeRangeDays" value="@Model.EffectiveTimeRangeDays" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Source Lens</p>
                <h2>Choose a category and source</h2>
                <p class="subtle-copy">Category selection controls every metric on this page. Source selection narrows the trend analysis without changing the category-wide ranking cards.</p>
            </div>
        </div>

        <form method="get" class="analytics-filter-grid two-up">
            <div>
                <label asp-for="CategoryKey" class="form-label">Category</label>
                <select asp-for="CategoryKey" class="form-select">
                    <option value="">Select a category</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryKey">@category.DisplayName</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="TimeRangeDays" class="form-label">Time range</label>
                <select asp-for="TimeRangeDays" class="form-select">
                    @foreach (var option in Model.TimeRangeOptions)
                    {
                        <option value="@option.Days">@option.Label</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="SourceName" class="form-label">Source</label>
                <select asp-for="SourceName" class="form-select">
                    <option value="">Highest-signal source</option>
                    @foreach (var sourceName in Model.AvailableSourceNames)
                    {
                        <option value="@sourceName">@sourceName</option>
                    }
                </select>
            </div>
            <div class="actions-bar analytics-filter-actions">
                <button type="submit" class="btn btn-dark">Load intelligence</button>
                <a asp-page="/Sources/Intelligence" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </section>

    @if (Model.IsAwaitingSelection)
    {
        <section class="panel panel-muted">
            <div class="empty-panel">
                <p class="empty-state">Select a category to load source trust, disagreement, completeness, and change activity trends.</p>
            </div>
        </section>
    }
    else if (Model.IsEmpty)
    {
        <section class="panel panel-muted">
            <div class="empty-panel">
                <p class="empty-state">No source intelligence is available for @Model.SelectedCategory?.DisplayName yet.</p>
            </div>
        </section>
    }
    else
    {
        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Triage</p>
                    <h2>Analyst starting points</h2>
                    <p class="subtle-copy">Use these signals to spot weak sources quickly, confirm high-value suppliers, and decide where to drill into trust and disagreement evidence.</p>
                </div>
            </div>

            <div class="analytics-card-grid">
                @foreach (var highlight in Model.TriageHighlights)
                {
                    <article class="analytics-card">
                        <div class="analytics-card-header">
                            <div>
                                <p class="eyebrow">@highlight.Label</p>
                                <strong>@highlight.Name</strong>
                            </div>
                            <span class="status-pill @highlight.Tone">@highlight.Value</span>
                        </div>
                        <p class="subtle-copy">@highlight.Description</p>
                    </article>
                }
            </div>
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Source Queues</p>
                    <h2>Weak and high-value watchlists</h2>
                </div>
            </div>

            <div class="analytics-filter-grid two-up">
                <article class="analytics-card">
                    <div class="analytics-card-header">
                        <div>
                            <strong>Weak sources</strong>
                            <p class="subtle-copy">Highest risk blend across trust drift, disagreement pressure, and coverage gaps.</p>
                        </div>
                    </div>

                    <div class="trend-stack">
                        @foreach (var metric in Model.WeakSources)
                        {
                            <article class="trend-card">
                                <div class="trend-card-header">
                                    <div>
                                        <strong>@metric.SourceName</strong>
                                        <p class="subtle-copy">@metric.HotspotCount hotspots, @metric.SupportedCategoryCount categories supported</p>
                                    </div>
                                    <span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetInverseTone(metric.RiskScore)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.RiskScore)</span>
                                </div>
                                <dl class="job-meta-grid compact">
                                    <div>
                                        <dt>Trust</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestTrustScore)</dd>
                                    </div>
                                    <div>
                                        <dt>Change</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestChangeActivity)</dd>
                                    </div>
                                    <div>
                                        <dt>Coverage</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestCoveragePercent)</dd>
                                    </div>
                                    <div>
                                        <dt>Extractability</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestExtractabilityRate)</dd>
                                    </div>
                                    <div>
                                        <dt>Trend</dt>
                                        <dd><span class="status-pill @Model.GetTrendDeltaTone(metric)">@Model.GetTrendDeltaText(metric)</span></dd>
                                    </div>
                                </dl>
                            </article>
                        }
                    </div>
                </article>

                <article class="analytics-card">
                    <div class="analytics-card-header">
                        <div>
                            <strong>High-value sources</strong>
                            <p class="subtle-copy">Best current blend of quality score, trust, completeness, and breadth.</p>
                        </div>
                    </div>

                    <div class="trend-stack">
                        @foreach (var metric in Model.HighValueSources)
                        {
                            <article class="trend-card">
                                <div class="trend-card-header">
                                    <div>
                                        <strong>@metric.SourceName</strong>
                                        <p class="subtle-copy">@metric.SourceProductCount products in @Model.SelectedCategory?.DisplayName</p>
                                    </div>
                                    <span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(metric.ValueScore)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.ValueScore)</span>
                                </div>
                                <dl class="job-meta-grid compact">
                                    <div>
                                        <dt>Quality</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.QualityScore)</dd>
                                    </div>
                                    <div>
                                        <dt>Trust</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestTrustScore)</dd>
                                    </div>
                                    <div>
                                        <dt>Coverage</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestCoveragePercent)</dd>
                                    </div>
                                    <div>
                                        <dt>No product</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestNoProductRate)</dd>
                                    </div>
                                    <div>
                                        <dt>Risk</dt>
                                        <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.RiskScore)</dd>
                                    </div>
                                </dl>
                            </article>
                        }
                    </div>
                </article>
            </div>
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Source Ranking</p>
                    <h2>Quality and trust overview</h2>
                </div>
            </div>

            <div class="analytics-card-grid">
                @foreach (var metric in Model.SourceOverview)
                {
                    <article class="analytics-card @(string.Equals(metric.SourceName, Model.EffectiveSourceName, StringComparison.OrdinalIgnoreCase) ? "attention" : string.Empty)">
                        <div class="analytics-card-header">
                            <div>
                                <strong>@metric.SourceName</strong>
                                <p class="subtle-copy">@metric.SourceProductCount products in @Model.SelectedCategory?.DisplayName, @metric.SupportedCategoryCount supported categories</p>
                            </div>
                            <span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(metric.ValueScore)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.ValueScore)</span>
                        </div>
                        <dl class="job-meta-grid compact">
                            <div>
                                <dt>Quality</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.QualityScore)</dd>
                            </div>
                            <div>
                                <dt>Trust</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestTrustScore)</dd>
                            </div>
                            <div>
                                <dt>Coverage</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestCoveragePercent)</dd>
                            </div>
                            <div>
                                <dt>Extractability</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestExtractabilityRate)</dd>
                            </div>
                            <div>
                                <dt>No product</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestNoProductRate)</dd>
                            </div>
                            <div>
                                <dt>Risk</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.RiskScore)</dd>
                            </div>
                            <div>
                                <dt>Change</dt>
                                <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestChangeActivity)</dd>
                            </div>
                            <div>
                                <dt>Hotspots</dt>
                                <dd>@metric.HotspotCount</dd>
                            </div>
                        </dl>
                    </article>
                }
            </div>
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Change Frequency</p>
                    <h2>Fast-moving sources</h2>
                    <p class="subtle-copy">Change activity is derived from the most recent spec stability snapshot inside @Model.TimeRangeLabel.ToLowerInvariant().</p>
                </div>
            </div>

            @if (Model.ChangeLeaders.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No change-frequency snapshots are available for the current selection.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table dashboard-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Source</th>
                                <th>Change activity</th>
                                <th>Trust drift</th>
                                <th>Conflict</th>
                                <th>Fetch success</th>
                                <th>No product</th>
                                <th>Hotspots</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var metric in Model.ChangeLeaders)
                            {
                                <tr>
                                    <td>@metric.SourceName</td>
                                    <td><span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetInverseTone(metric.LatestChangeActivity)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestChangeActivity)</span></td>
                                    <td><span class="status-pill @Model.GetTrendDeltaTone(metric)">@Model.GetTrendDeltaText(metric)</span></td>
                                    <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestConflictRate)</td>
                                    <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestSuccessfulCrawlRate)</td>
                                    <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestNoProductRate)</td>
                                    <td>@metric.HotspotCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Coverage Completeness</p>
                    <h2>@Model.SelectedCategory?.DisplayName source coverage</h2>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table dashboard-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Coverage</th>
                            <th>Agreement</th>
                            <th>Mapped attrs</th>
                            <th>Confidence</th>
                            <th>Gap</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var metric in Model.CoverageLeaders)
                        {
                            <tr>
                                <td>@metric.SourceName</td>
                                <td><span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(metric.LatestCoveragePercent)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.LatestCoveragePercent)</span></td>
                                <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.AgreementPercent)</td>
                                <td>@metric.AverageMappedAttributes</td>
                                <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(metric.AverageAttributeConfidence)</td>
                                <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(100m - metric.LatestCoveragePercent)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Trust Over Time</p>
                    <h2>@(Model.EffectiveSourceName ?? "Selected source") trust timeline</h2>
                    <p class="subtle-copy">Focused source trends stay scoped to @Model.TimeRangeLabel.ToLowerInvariant(). Category ranking cards stay category-wide.</p>
                </div>
            </div>

            @if (Model.TrendSnapshots.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No trust history is available for the current category and source.</p>
                </div>
            }
            else
            {
                <div class="trend-stack">
                    @foreach (var snapshot in Model.TrendSnapshots)
                    {
                        var changeActivity = ProductNormaliser.Web.Models.AnalyticsPresentation.GetChangeActivity(snapshot);

                        <article class="trend-card">
                            <div class="trend-card-header">
                                <div>
                                    <strong>@snapshot.SourceName</strong>
                                    <p class="subtle-copy">@snapshot.TimestampUtc.ToString("u")</p>
                                </div>
                                <span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(snapshot.HistoricalTrustScore)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.HistoricalTrustScore)</span>
                            </div>

                            <div class="analytics-trend-grid">
                                <div>
                                    <span>Trust</span>
                                    <div class="analytics-meter-shell"><div class="analytics-meter-fill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(snapshot.HistoricalTrustScore)" style="@ProductNormaliser.Web.Models.AnalyticsPresentation.GetWidthStyle(snapshot.HistoricalTrustScore)"></div></div>
                                </div>
                                <div>
                                    <span>Completeness</span>
                                    <div class="analytics-meter-shell"><div class="analytics-meter-fill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetPositiveTone(snapshot.AttributeCoverage)" style="@ProductNormaliser.Web.Models.AnalyticsPresentation.GetWidthStyle(snapshot.AttributeCoverage)"></div></div>
                                </div>
                                <div>
                                    <span>Change activity</span>
                                    <div class="analytics-meter-shell"><div class="analytics-meter-fill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetInverseTone(changeActivity)" style="@ProductNormaliser.Web.Models.AnalyticsPresentation.GetWidthStyle(changeActivity)"></div></div>
                                </div>
                            </div>

                            <dl class="job-meta-grid compact">
                                <div>
                                    <dt>Agreement</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.AgreementRate)</dd>
                                </div>
                                <div>
                                    <dt>Conflict</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.ConflictRate)</dd>
                                </div>
                                <div>
                                    <dt>Crawl success</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.SuccessfulCrawlRate)</dd>
                                </div>
                                <div>
                                    <dt>Extractability</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.ExtractabilityRate)</dd>
                                </div>
                                <div>
                                    <dt>No product</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.NoProductRate)</dd>
                                </div>
                                <div>
                                    <dt>Spec stability</dt>
                                    <dd>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(snapshot.SpecStabilityScore)</dd>
                                </div>
                            </dl>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Hotspots</p>
                    <h2>Disagreement hotspots</h2>
                    <p class="subtle-copy">This hotspot table is category-wide for @Model.TimeRangeLabel.ToLowerInvariant(), so you can see where the selected source diverges from broader supplier pressure.</p>
                </div>
                <a asp-page-handler="ExportDisagreements"
                   asp-route-category="@Model.CategoryKey"
                   asp-route-source="@Model.SourceName"
                   asp-route-range="@Model.EffectiveTimeRangeDays"
                   class="btn btn-outline-dark">Export disagreements CSV</a>
            </div>

            @if (Model.DisagreementHotspots.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No disagreement hotspots are available for the current selection.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table dashboard-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Attribute</th>
                                <th>Source</th>
                                <th>Disagreement rate</th>
                                <th>Wins</th>
                                <th>Comparisons</th>
                                <th>Last updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.DisagreementHotspots)
                            {
                                <tr>
                                    <td class="mono">@item.AttributeKey</td>
                                    <td>@item.SourceName</td>
                                    <td><span class="status-pill @ProductNormaliser.Web.Models.AnalyticsPresentation.GetInverseTone(item.DisagreementRate)">@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(item.DisagreementRate)</span></td>
                                    <td>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(item.WinRate)</td>
                                    <td>@item.TotalComparisons</td>
                                    <td>@item.LastUpdatedUtc.ToString("u")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="panel panel-muted inspector-section">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Support Matrix</p>
                    <h2>Source support by commodity</h2>
                    <p class="subtle-copy">Rows show active suppliers. The selected category column surfaces the current quality score; other columns show whether the source is assigned and ready for that commodity.</p>
                </div>
            </div>

            @if (Model.SupportMatrixRows.Count == 0)
            {
                <div class="empty-panel">
                    <p class="empty-state">No source support assignments are available yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table dashboard-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Source</th>
                                <th>Status</th>
                                @foreach (var category in Model.SupportMatrixCategories)
                                {
                                    <th>@category.DisplayName</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.SupportMatrixRows)
                            {
                                <tr>
                                    <td>
                                        <strong>@row.SourceName</strong>
                                        <div class="subtle-copy">@row.SupportedCategoryCount categories</div>
                                    </td>
                                    <td>@row.ReadinessStatus</td>
                                    @foreach (var cell in row.Cells)
                                    {
                                        <td>
                                            <span class="status-pill @cell.Tone">@cell.Label</span>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</section>
