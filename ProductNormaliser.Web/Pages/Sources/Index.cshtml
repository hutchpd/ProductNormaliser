@page
@model ProductNormaliser.Web.Pages.Sources.IndexModel
@{
    ViewData["Title"] = "Sources";
}

<section class="dashboard-shell">
    <partial name="_PageHero" model="Model.Hero" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="notice error" role="alert"></div>

    <div class="overview-grid">
        <section class="panel panel-muted">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Boot And Populate</p>
                    <h2>Registry startup posture</h2>
                </div>
            </div>

            <div class="metric-strip">
                <article>
                    <span>Registered</span>
                    <strong>@Model.TotalSources</strong>
                </article>
                <article>
                    <span>Enabled</span>
                    <strong>@Model.RegistryEnabledSources</strong>
                </article>
                <article>
                    <span>Discovery-configured</span>
                    <strong>@Model.RegistryDiscoveryConfiguredSources</strong>
                </article>
                <article>
                    <span>Boot-ready</span>
                    <strong>@Model.RegistryBootReadySources</strong>
                </article>
            </div>

            <div class="empty-panel mt-3">
                <p class="empty-state">Register a source, assign categories such as TV, Monitor, or Laptop, then adjust its discovery profile only if the startup defaults need tightening.</p>
                <p class="subtle-copy">New sources start with conservative robots-on throttling plus bounded discovery seeds, sitemap hints, and retry limits so category launches can populate immediately.</p>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Add Source</p>
                    <h2>Register a new crawl host</h2>
                </div>
            </div>

            <form method="post" asp-page-handler="Register" class="source-form">
                <div class="form-grid">
                    <div>
                        <label asp-for="Registration.SourceId" class="form-label"></label>
                        <input asp-for="Registration.SourceId" class="form-control" placeholder="northwind_store" />
                        <span asp-validation-for="Registration.SourceId" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Registration.DisplayName" class="form-label"></label>
                        <input asp-for="Registration.DisplayName" class="form-control" placeholder="Northwind" />
                        <span asp-validation-for="Registration.DisplayName" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Registration.BaseUrl" class="form-label"></label>
                        <input asp-for="Registration.BaseUrl" class="form-control" placeholder="https://www.northwind.example/" />
                        <span asp-validation-for="Registration.BaseUrl" class="text-danger small"></span>
                    </div>
                    <div class="wide">
                        <label asp-for="Registration.Description" class="form-label"></label>
                        <textarea asp-for="Registration.Description" rows="2" class="form-control" placeholder="Optional operator note about this source"></textarea>
                    </div>
                    <div>
                        <label asp-for="Registration.PreferredLocale" class="form-label"></label>
                        <input asp-for="Registration.PreferredLocale" class="form-control" placeholder="en-GB" />
                    </div>
                    <div>
                        <label asp-for="Registration.AutomationMode" class="form-label"></label>
                        <select asp-for="Registration.AutomationMode" class="form-control">
                            <option value="operator_assisted">Operator-assisted</option>
                            <option value="suggest_accept">Suggest accept</option>
                            <option value="auto_accept_and_seed">Auto-accept and seed</option>
                        </select>
                        <span class="subtle-copy">Stored as the source's visible onboarding policy. Defaults to operator-assisted.</span>
                    </div>
                </div>

                <div>
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Market Controls</p>
                            <h2>Restrict allowed markets</h2>
                        </div>
                    </div>

                    <div class="check-grid">
                        @foreach (var market in new[] { "UK", "IE", "EU", "US" })
                        {
                            <label class="check-card">
                                <input type="checkbox"
                                       name="Registration.AllowedMarkets"
                                       value="@market"
                                       checked="@Model.Registration.AllowedMarkets.Contains(market, StringComparer.OrdinalIgnoreCase)" />
                                <span>
                                    <strong>@market</strong>
                                    <span class="subtle-copy d-block">Approved onboarding market</span>
                                </span>
                            </label>
                        }
                    </div>
                </div>

                <div>
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Categories</p>
                            <h2>Select crawl coverage</h2>
                        </div>
                    </div>

                    <div class="check-grid">
                    @foreach (var category in Model.Categories)
                    {
                        <label class="check-card @(category.IsEnabled ? string.Empty : "disabled")">
                            <input type="checkbox"
                                   name="Registration.CategoryKeys"
                                   value="@category.CategoryKey"
                                   checked="@Model.Registration.CategoryKeys.Contains(category.CategoryKey)"
                                   disabled="@(!category.IsEnabled)" />
                            <span>
                                <strong>@category.DisplayName</strong>
                                <span class="subtle-copy d-block">@category.CrawlSupportStatus</span>
                            </span>
                        </label>
                    }
                    </div>
                </div>

                <label class="form-check">
                    <input asp-for="Registration.IsEnabled" class="form-check-input" />
                    <span class="form-check-label">Enable this source immediately after registration</span>
                </label>

                <div class="actions-bar">
                    <button type="submit" class="btn btn-dark">Register source</button>
                </div>
            </form>
        </section>
    </div>

    <section class="panel panel-muted">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Candidate Discovery</p>
                <h2>Search likely source hosts before registration</h2>
            </div>
        </div>

        <div class="empty-panel mt-3">
                <p class="empty-state">Start a persisted discovery run for the selected categories, then review live stage progress and candidate decisions from the dedicated run details page.</p>
            <p class="subtle-copy">Automation stays opt-in. Operator-assisted remains the default, suggestion mode only labels safe candidates, and guarded auto-accept plus seeding only runs when the visible thresholds and guardrails pass.</p>
        </div>

        @if (Model.HasAutomationLlmStatusNotice())
        {
            <div class="@Model.GetLlmStatusNoticeClass(Model.AutomationSettings.LlmStatus)">
                <strong>@Model.GetLlmStatusTitle(Model.AutomationSettings.LlmStatus)</strong>
                <div>@Model.AutomationSettings.LlmStatusMessage</div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.CandidateDiscoveryErrorMessage))
        {
            <div class="notice error">@Model.CandidateDiscoveryErrorMessage</div>
        }

        <form method="post" asp-page-handler="DiscoverCandidates" class="source-form" data-discovery-form>
            <div>
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Categories</p>
                        <h2>Select discovery scope</h2>
                    </div>
                </div>

                <div class="check-grid">
                @foreach (var category in Model.Categories)
                {
                    <label class="check-card @(category.IsEnabled ? string.Empty : "disabled")">
                        <input type="checkbox"
                               name="CandidateDiscovery.CategoryKeys"
                               value="@category.CategoryKey"
                               checked="@Model.CandidateDiscovery.CategoryKeys.Contains(category.CategoryKey)"
                               disabled="@(!category.IsEnabled)" />
                        <span>
                            <strong>@category.DisplayName</strong>
                            <span class="subtle-copy d-block">@category.CrawlSupportStatus</span>
                        </span>
                    </label>
                }
                </div>
                <span asp-validation-for="CandidateDiscovery.CategoryKeys" class="text-danger small"></span>
            </div>

            <div class="form-grid">
                <div>
                    <label asp-for="CandidateDiscovery.Locale" class="form-label"></label>
                    <input asp-for="CandidateDiscovery.Locale" class="form-control" placeholder="en-GB" />
                </div>
                <div>
                    <label asp-for="CandidateDiscovery.Market" class="form-label"></label>
                    <input asp-for="CandidateDiscovery.Market" class="form-control" placeholder="UK" />
                </div>
                <div>
                    <label asp-for="CandidateDiscovery.MaxCandidates" class="form-label"></label>
                    <input asp-for="CandidateDiscovery.MaxCandidates" class="form-control" min="1" max="25" />
                    <span asp-validation-for="CandidateDiscovery.MaxCandidates" class="text-danger small"></span>
                </div>
                <div>
                    <label asp-for="CandidateDiscovery.AutomationMode" class="form-label"></label>
                    <select asp-for="CandidateDiscovery.AutomationMode" class="form-control">
                        <option value="operator_assisted">Operator-assisted only</option>
                        <option value="suggest_accept">Suggest safe candidates</option>
                        <option value="auto_accept_and_seed">Guarded auto-accept and seed</option>
                    </select>
                </div>
                <div class="wide">
                    <label asp-for="CandidateDiscovery.BrandHints" class="form-label"></label>
                    <textarea asp-for="CandidateDiscovery.BrandHints" rows="2" class="form-control" placeholder="Samsung, LG, Sony"></textarea>
                    <span class="subtle-copy">Optional hints only. They do not create any sources or change crawl launch behavior.</span>
                </div>
            </div>

            <div class="detail-grid mt-3">
                <div>
                    <dt>Current mode</dt>
                    <dd>@Model.GetAutomationModeLabel(Model.CandidateDiscovery.AutomationMode)</dd>
                </div>
                <div>
                    <dt>Suggestion threshold</dt>
                    <dd>@Model.AutomationSettings.SuggestMinConfidenceScore.ToString("0.#") confidence</dd>
                </div>
                <div>
                    <dt>Auto-accept threshold</dt>
                    <dd>@Model.AutomationSettings.AutoAcceptMinConfidenceScore.ToString("0.#") confidence</dd>
                </div>
                <div>
                    <dt>Duplicate-risk cap</dt>
                    <dd>@Model.AutomationSettings.MaxDuplicateRiskScore.ToString("0.#") max risk score</dd>
                </div>
                <div>
                    <dt>Auto cap per run</dt>
                    <dd>@Model.AutomationSettings.MaxAutoAcceptedCandidatesPerRun</dd>
                </div>
                <div>
                    <dt>Guarded quality floors</dt>
                    <dd>@Model.AutomationSettings.MinCrawlabilityScore.ToString("0.#") crawlability / @Model.AutomationSettings.MinCategoryRelevanceScore.ToString("0.#") category relevance / @Model.AutomationSettings.MinCatalogLikelihoodScore.ToString("0.#") catalog likelihood</dd>
                </div>
                <div>
                    <dt>Runtime evidence floors</dt>
                    <dd>@Model.AutomationSettings.MinExtractabilityScore.ToString("0.#") extractability / @Model.AutomationSettings.MinYieldConfidenceScore.ToString("0.#") yield confidence</dd>
                </div>
                <div>
                    <dt>Probe budget</dt>
                    <dd>@Model.AutomationSettings.AutomationCategorySampleBudget.ToString("0") category pages / @Model.AutomationSettings.AutomationProductSampleBudget.ToString("0") product pages</dd>
                </div>
                <div>
                    <dt>Suggestion breadth</dt>
                    <dd>@Model.AutomationSettings.SuggestMinReachableCategorySamples.ToString("0") category / @Model.AutomationSettings.SuggestMinReachableProductSamples.ToString("0") product / @Model.AutomationSettings.SuggestMinRuntimeCompatibleProductSamples.ToString("0") runtime-compatible</dd>
                </div>
                <div>
                    <dt>Auto-accept breadth</dt>
                    <dd>@Model.AutomationSettings.AutoAcceptMinReachableCategorySamples.ToString("0") category / @Model.AutomationSettings.AutoAcceptMinReachableProductSamples.ToString("0") product / @Model.AutomationSettings.AutoAcceptMinRuntimeCompatibleProductSamples.ToString("0") runtime-compatible / @Model.AutomationSettings.AutoAcceptMinStructuredEvidenceProductSamples.ToString("0") structured</dd>
                </div>
            </div>

            <div class="actions-bar">
                <button type="submit" class="btn btn-dark" data-discovery-submit>Start discovery run</button>
            </div>

            <div class="notice info discovery-submit-feedback" data-discovery-submit-status hidden aria-live="polite">
                <div class="discovery-submit-feedback-body">
                    <strong data-discovery-submit-title>Creating discovery run</strong>
                    <div data-discovery-submit-message>The worker will search, probe, and locally verify candidate hosts in the background.</div>
                    <div class="subtle-copy" data-discovery-submit-elapsed></div>
                    <div class="discovery-submit-stages">
                        <span data-discovery-stage="search">Search hosts</span>
                        <span data-discovery-stage="probe">Probe pages</span>
                        <span data-discovery-stage="llm">Local verification queue</span>
                    </div>
                </div>
            </div>
        </form>
    </section>

    <section class="panel panel-muted">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Run History</p>
                <h2>Recent discovery runs</h2>
            </div>
        </div>

        <div class="metric-strip">
            <article>
                <span>Visible runs</span>
                <strong>@(Model.ExpandedDiscoveryRuns.Count + Model.CollapsedDiscoveryRuns.Count)</strong>
            </article>
            <article>
                <span>Active</span>
                <strong>@Model.ActiveDiscoveryRunCount</strong>
            </article>
            <article>
                <span>Expanded</span>
                <strong>@Model.ExpandedDiscoveryRuns.Count</strong>
            </article>
            <article>
                <span>Collapsed older runs</span>
                <strong>@Model.CollapsedDiscoveryRuns.Count</strong>
            </article>
        </div>

        @if (Model.ExpandedDiscoveryRuns.Count == 0 && !Model.HasCollapsedDiscoveryRuns)
        {
            <div class="empty-panel mt-3">
                <p class="empty-state">No persisted discovery runs yet.</p>
                <p class="subtle-copy">Start a discovery run above to create a background record with archive, suppression, and recovery history.</p>
            </div>
        }
        else
        {
            <div class="job-card-grid mt-3">
            @foreach (var run in Model.ExpandedDiscoveryRuns)
            {
                var badge = ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStatusBadge(run.Status);

                <article class="job-card">
                    <div class="job-card-header">
                        <div>
                            <strong>@run.RunId</strong>
                            <div class="subtle-copy">@Model.GetDiscoveryRunScopeSummary(run)</div>
                            <div class="subtle-copy">Created @run.CreatedUtc.ToString("u")</div>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = badge.Text, Tone = badge.Tone }' />
                            <span class="chip">@ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStageLabel(run.CurrentStage)</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(run.StatusMessage))
                    {
                        <p class="subtle-copy mt-2">@run.StatusMessage</p>
                    }

                    <div class="chip-row compact-wrap mt-2">
                        <span class="chip">@Model.GetAutomationModeLabel(run.AutomationMode)</span>
                        <span class="chip">@run.SearchResultCount search hits</span>
                        <span class="chip">@run.CollapsedCandidateCount candidates</span>
                        <span class="chip">@run.ProbeCompletedCount probes completed</span>
                        @if (run.RecoveryAttemptCount > 0)
                        {
                            <span class="chip">recovery attempts @run.RecoveryAttemptCount</span>
                        }
                    </div>

                    <div class="subtle-copy mt-2">@Model.GetDiscoveryRunOutcomeSummary(run)</div>

                    @if (!string.IsNullOrWhiteSpace(Model.GetDiscoveryRunTimingSummary(run)))
                    {
                        <div class="subtle-copy mt-1">@Model.GetDiscoveryRunTimingSummary(run)</div>
                    }

                    <div class="actions-bar inline-actions mt-3">
                        <a asp-page="/Sources/DiscoveryRuns/Details" asp-route-runId="@run.RunId" class="btn btn-outline-dark">Open run</a>
                    </div>
                </article>
            }
            </div>

            @if (Model.HasCollapsedDiscoveryRuns)
            {
                <details class="candidate-detail-disclosure mt-3">
                    <summary>Show @Model.CollapsedDiscoveryRuns.Count older run(s)</summary>

                    <div class="job-card-grid mt-3">
                    @foreach (var run in Model.CollapsedDiscoveryRuns)
                    {
                        var badge = ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStatusBadge(run.Status);

                        <article class="job-card">
                            <div class="job-card-header">
                                <div>
                                    <strong>@run.RunId</strong>
                                    <div class="subtle-copy">@Model.GetDiscoveryRunScopeSummary(run)</div>
                                    <div class="subtle-copy">Created @run.CreatedUtc.ToString("u")</div>
                                </div>
                                <div class="d-flex flex-column align-items-end gap-2">
                                    <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = badge.Text, Tone = badge.Tone }' />
                                    <span class="chip">@ProductNormaliser.Web.Models.DiscoveryRunPresentation.GetStageLabel(run.CurrentStage)</span>
                                </div>
                            </div>

                            <div class="subtle-copy mt-2">@Model.GetDiscoveryRunOutcomeSummary(run)</div>

                            @if (!string.IsNullOrWhiteSpace(Model.GetDiscoveryRunTimingSummary(run)))
                            {
                                <div class="subtle-copy mt-1">@Model.GetDiscoveryRunTimingSummary(run)</div>
                            }

                            <div class="actions-bar inline-actions mt-3">
                                <a asp-page="/Sources/DiscoveryRuns/Details" asp-route-runId="@run.RunId" class="btn btn-outline-dark">Open run</a>
                            </div>
                        </article>
                    }
                    </div>
                </details>
            }
        }
    </section>

    @if (Model.CandidateDiscoveryResult is not null)
    {
        var visibleCandidates = Model.GetVisibleCandidateResults();
        var archivedCandidates = Model.GetArchivedCandidateResults();

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Discovery Results</p>
                    <h2>Ephemeral source candidates</h2>
                </div>
            </div>

            <div class="metric-strip">
                <article>
                    <span>Requested categories</span>
                    <strong>@Model.CandidateDiscoveryResult.RequestedCategoryKeys.Count</strong>
                </article>
                <article>
                    <span>Returned candidates</span>
                    <strong>@Model.CandidateDiscoveryResult.Candidates.Count</strong>
                </article>
                <article>
                    <span>Diagnostics</span>
                    <strong>@Model.CandidateDiscoveryResult.Diagnostics.Count</strong>
                </article>
                <article>
                    <span>Already registered</span>
                    <strong>@Model.CandidateDiscoveryResult.Candidates.Count(candidate => candidate.AlreadyRegistered)</strong>
                </article>
                <article>
                    <span>Generated</span>
                    <strong>@Model.CandidateDiscoveryResult.GeneratedUtc.ToString("u")</strong>
                </article>
            </div>

            @if (Model.CandidateDiscoveryResult.Diagnostics.Count > 0)
            {
                <div class="mt-3 d-flex flex-column gap-2">
                @foreach (var diagnostic in Model.CandidateDiscoveryResult.Diagnostics)
                {
                    <div class="@Model.GetDiscoveryDiagnosticNoticeClass(diagnostic)">
                        <strong>@diagnostic.Title</strong>
                        <div>@diagnostic.Message</div>
                    </div>
                }
                </div>
            }

            @if (Model.HasDiscoveryLlmStatusNotice())
            {
                <div class="mt-3 @Model.GetLlmStatusNoticeClass(Model.CandidateDiscoveryResult.LlmStatus)">
                    <strong>@Model.GetLlmStatusTitle(Model.CandidateDiscoveryResult.LlmStatus)</strong>
                    <div>@Model.CandidateDiscoveryResult.LlmStatusMessage</div>
                </div>
            }

            @if (Model.CandidateDiscoveryResult.Candidates.Count == 0)
            {
                <div class="empty-panel mt-3">
                    <p class="empty-state">@Model.GetCandidateDiscoveryEmptyStateHeading()</p>
                    <p class="subtle-copy">@Model.GetCandidateDiscoveryEmptyStateMessage()</p>
                </div>
            }
            else if (visibleCandidates.Count == 0)
            {
                <div class="empty-panel mt-3">
                    <p class="empty-state">All candidates from this run are archived.</p>
                    <p class="subtle-copy">Restore a candidate from the archive below when you want it back in the active review queue.</p>
                </div>
            }
            else
            {
                <div class="candidate-results-toolbar mt-3" data-candidate-results>
                    <p class="subtle-copy mb-0">Showing @visibleCandidates.Count active candidate(s) first. Expand a candidate when you need the full probe evidence.@(archivedCandidates.Count > 0 ? $" {archivedCandidates.Count} candidate(s) are archived for this run." : string.Empty)</p>
                    <div class="candidate-results-pager" data-candidate-pager data-page-size="3">
                        <button type="button" class="btn btn-outline-secondary" data-candidate-prev>Previous</button>
                        <span class="subtle-copy" data-candidate-page-status></span>
                        <button type="button" class="btn btn-outline-secondary" data-candidate-next>Next</button>
                    </div>
                </div>

                <div class="job-card-grid mt-3" data-candidate-results-list>
                @foreach (var candidate in visibleCandidates)
                {
                    <article class="job-card @(candidate.AlreadyRegistered ? "attention" : string.Empty)" data-candidate-card>
                        <div class="job-card-header">
                            <div>
                                <strong>@candidate.DisplayName</strong>
                                <div class="subtle-copy mono">@candidate.Host</div>
                                <div class="subtle-copy">@candidate.BaseUrl</div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-2">
                                <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = Model.GetCandidateRecommendationLabel(candidate), Tone = Model.GetCandidateRecommendationTone(candidate) }' />
                                <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = Model.GetAutomationDecisionLabel(candidate), Tone = Model.GetAutomationDecisionTone(candidate) }' />
                                <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = Model.GetRuntimeExtractionLabel(candidate), Tone = Model.GetRuntimeExtractionTone(candidate) }' />
                                <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = $"{candidate.ConfidenceScore:0.#}% confidence", Tone = candidate.AllowedByGovernance ? "completed" : "warning" }' />
                            </div>
                        </div>

                        <div class="chip-row compact-wrap">
                            <span class="chip">@candidate.CandidateType</span>
                            @foreach (var market in candidate.AllowedMarkets)
                            {
                                <span class="chip">@market</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(candidate.PreferredLocale))
                            {
                                <span class="chip">@candidate.PreferredLocale</span>
                            }
                            <span class="chip">market: @candidate.MarketEvidence</span>
                            <span class="chip">locale: @candidate.LocaleEvidence</span>
                            @foreach (var categoryKey in candidate.MatchedCategoryKeys)
                            {
                                <span class="chip">@categoryKey</span>
                            }
                            @if (candidate.AlreadyRegistered)
                            {
                                <span class="chip">Matches registered source</span>
                            }
                        </div>

                        @if (candidate.DuplicateSourceDisplayNames.Count > 0)
                        {
                            <p class="subtle-copy mt-2">Duplicate match: @string.Join(", ", candidate.DuplicateSourceDisplayNames)</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(candidate.GovernanceWarning))
                        {
                            <p class="text-danger small mt-2">Governance warning: @candidate.GovernanceWarning</p>
                        }

                        <dl class="job-meta-grid compact mt-3">
                            <div><dt>Robots</dt><dd>@(candidate.Probe.RobotsTxtReachable ? "Reachable" : "Unknown")</dd></div>
                            <div><dt>Sitemap</dt><dd>@(candidate.Probe.SitemapDetected ? "Detected" : "None")</dd></div>
                            <div><dt>Crawlability</dt><dd>@candidate.CrawlabilityScore.ToString("0.#")</dd></div>
                            <div><dt>Relevance</dt><dd>@candidate.Probe.CategoryRelevanceScore.ToString("0.#")</dd></div>
                            <div><dt>Extractability</dt><dd>@candidate.ExtractabilityScore.ToString("0.#")</dd></div>
                            <div><dt>Runtime extraction</dt><dd>@(candidate.Probe.RuntimeExtractionCompatible ? $"{candidate.Probe.RepresentativeRuntimeProductCount} product(s)" : "No products extracted")</dd></div>
                            <div><dt>Catalog fit</dt><dd>@candidate.Probe.CatalogLikelihoodScore.ToString("0.#")</dd></div>
                            <div><dt>Duplicate risk</dt><dd>@candidate.DuplicateRiskScore.ToString("0.#")</dd></div>
                        </dl>

                        <p class="subtle-copy mt-2">@candidate.RuntimeExtractionMessage</p>

                        @if (!string.IsNullOrWhiteSpace(Model.GetCandidateProbeTimingSummary(candidate)) || !string.IsNullOrWhiteSpace(Model.GetCandidateLlmTimingSummary(candidate)))
                        {
                            <div class="chip-row compact-wrap candidate-timing-row">
                                @if (!string.IsNullOrWhiteSpace(Model.GetCandidateProbeTimingSummary(candidate)))
                                {
                                    <span class="chip">@Model.GetCandidateProbeTimingSummary(candidate)</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.GetCandidateLlmTimingSummary(candidate)))
                                {
                                    <span class="chip">@Model.GetCandidateLlmTimingSummary(candidate)</span>
                                }
                            </div>
                        }

                        @if (Model.GetCandidatePrimaryReasons(candidate).Count > 0)
                        {
                            <div class="candidate-summary-section">
                                <div class="subtle-copy">Why it surfaced</div>
                                <ul class="small mb-0 candidate-summary-list">
                                @foreach (var reason in Model.GetCandidatePrimaryReasons(candidate))
                                {
                                    <li>@reason</li>
                                }
                                </ul>
                            </div>
                        }

                        @if (Model.GetCandidatePrimaryBlockers(candidate).Count > 0)
                        {
                            <div class="candidate-summary-section">
                                <div class="subtle-copy">Main blockers</div>
                                <ul class="small mb-0 candidate-summary-list">
                                @foreach (var reason in Model.GetCandidatePrimaryBlockers(candidate))
                                {
                                    <li>@reason</li>
                                }
                                </ul>
                            </div>
                        }

                        @if (Model.HasCandidateExpandedDetail(candidate))
                        {
                            <details class="candidate-detail-disclosure">
                                <summary>View evidence and probe detail</summary>

                                <div>
                                    <div class="subtle-copy mt-3">Automation assessment</div>
                                    <ul class="small mb-0">
                                        @foreach (var reason in candidate.AutomationAssessment.SupportingReasons)
                                        {
                                            <li>@reason</li>
                                        }
                                        @foreach (var reason in candidate.AutomationAssessment.BlockingReasons)
                                        {
                                            <li>@reason</li>
                                        }
                                    </ul>
                                </div>

                                @if (candidate.Probe.RepresentativeCategoryPageReachable || candidate.Probe.RepresentativeProductPageReachable || candidate.Probe.StructuredProductEvidenceDetected || candidate.Probe.TechnicalAttributeEvidenceDetected)
                                {
                                    <div>
                                        <div class="subtle-copy mt-3">Representative evidence</div>
                                        <ul class="small mb-0">
                                            <li>Category page: @(candidate.Probe.RepresentativeCategoryPageReachable ? "reachable" : "not confirmed")@(string.IsNullOrWhiteSpace(candidate.Probe.RepresentativeCategoryPageUrl) ? string.Empty : $" ({candidate.Probe.RepresentativeCategoryPageUrl})")</li>
                                            <li>Product page: @(candidate.Probe.RepresentativeProductPageReachable ? "reachable" : "not confirmed")@(string.IsNullOrWhiteSpace(candidate.Probe.RepresentativeProductPageUrl) ? string.Empty : $" ({candidate.Probe.RepresentativeProductPageUrl})")</li>
                                            <li>Runtime extraction: @(candidate.Probe.RuntimeExtractionCompatible ? $"compatible ({candidate.Probe.RepresentativeRuntimeProductCount} product(s) extracted)" : "not compatible")</li>
                                            <li>Structured product evidence: @(candidate.Probe.StructuredProductEvidenceDetected ? "detected" : "not detected")</li>
                                            <li>Technical attribute evidence: @(candidate.Probe.TechnicalAttributeEvidenceDetected ? "detected" : "not detected")</li>
                                        </ul>
                                    </div>
                                }

                                @if (candidate.Reasons.Count > 3)
                                {
                                    <div>
                                        <div class="subtle-copy mt-3">All discovery reasons</div>
                                        <ul class="small mb-0">
                                        @foreach (var reason in candidate.Reasons.Skip(3))
                                        {
                                            <li>@reason.Message</li>
                                        }
                                        </ul>
                                    </div>
                                }

                                @if (candidate.Probe.LikelyListingUrlPatterns.Count > 0 || candidate.Probe.LikelyProductUrlPatterns.Count > 0 || candidate.Probe.SitemapUrls.Count > 0)
                                {
                                    <div>
                                        <div class="subtle-copy mt-3">Probe hints</div>
                                        <ul class="small mb-0">
                                            @foreach (var sitemapUrl in Model.GetCandidateVisibleSitemapHints(candidate))
                                            {
                                                <li>Sitemap: @sitemapUrl</li>
                                            }
                                            @if (Model.GetCandidateHiddenSitemapHintCount(candidate) > 0)
                                            {
                                                <li>Plus @Model.GetCandidateHiddenSitemapHintCount(candidate) additional sitemap hint(s).</li>
                                            }
                                            @foreach (var pattern in candidate.Probe.LikelyListingUrlPatterns)
                                            {
                                                <li>Listing pattern: @pattern</li>
                                            }
                                            @foreach (var pattern in candidate.Probe.LikelyProductUrlPatterns)
                                            {
                                                <li>Product pattern: @pattern</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </details>
                        }

                        @if (candidate.Probe.NonCatalogContentHeavy)
                        {
                            <p class="subtle-copy mt-2">Sampled pages look more support, blog, or marketing heavy than product-catalog heavy.</p>
                        }

                        <div class="actions-bar mt-3">
                            <form method="post" asp-page-handler="UseCandidate">
                                <input type="hidden" asp-for="CandidateSelection.CandidateKey" value="@candidate.CandidateKey" />
                                <input type="hidden" asp-for="CandidateSelection.DisplayName" value="@candidate.DisplayName" />
                                <input type="hidden" asp-for="CandidateSelection.BaseUrl" value="@candidate.BaseUrl" />
                                <input type="hidden" asp-for="CandidateSelection.IsEnabled" value="true" />
                                @foreach (var market in candidate.AllowedMarkets)
                                {
                                    <input type="hidden" name="CandidateSelection.AllowedMarkets" value="@market" />
                                }
                                <input type="hidden" asp-for="CandidateSelection.PreferredLocale" value="@candidate.PreferredLocale" />
                                @foreach (var categoryKey in candidate.MatchedCategoryKeys)
                                {
                                    <input type="hidden" name="CandidateSelection.CategoryKeys" value="@categoryKey" />
                                }
                                @foreach (var categoryKey in Model.CandidateDiscovery.CategoryKeys)
                                {
                                    <input type="hidden" name="CandidateDiscovery.CategoryKeys" value="@categoryKey" />
                                }
                                <input type="hidden" asp-for="CandidateDiscovery.Locale" />
                                <input type="hidden" asp-for="CandidateDiscovery.Market" />
                                <input type="hidden" asp-for="CandidateDiscovery.BrandHints" />
                                <input type="hidden" asp-for="CandidateDiscovery.AutomationMode" />
                                <input type="hidden" asp-for="CandidateDiscovery.MaxCandidates" />
                                @foreach (var dismissedCandidateKey in Model.CandidateDiscovery.DismissedCandidateKeys)
                                {
                                    <input type="hidden" name="CandidateDiscovery.DismissedCandidateKeys" value="@dismissedCandidateKey" />
                                }
                                <button type="submit" class="btn btn-outline-secondary">Use candidate</button>
                            </form>

                            @if (Model.CanAcceptCandidate(candidate))
                            {
                                <form method="post" asp-page-handler="AcceptCandidate">
                                    <input type="hidden" asp-for="CandidateSelection.CandidateKey" value="@candidate.CandidateKey" />
                                    <input type="hidden" asp-for="CandidateSelection.DisplayName" value="@candidate.DisplayName" />
                                    <input type="hidden" asp-for="CandidateSelection.BaseUrl" value="@candidate.BaseUrl" />
                                    <input type="hidden" asp-for="CandidateSelection.IsEnabled" value="true" />
                                    @foreach (var market in candidate.AllowedMarkets)
                                    {
                                        <input type="hidden" name="CandidateSelection.AllowedMarkets" value="@market" />
                                    }
                                    <input type="hidden" asp-for="CandidateSelection.PreferredLocale" value="@candidate.PreferredLocale" />
                                    @foreach (var categoryKey in candidate.MatchedCategoryKeys)
                                    {
                                        <input type="hidden" name="CandidateSelection.CategoryKeys" value="@categoryKey" />
                                    }
                                    @foreach (var categoryKey in Model.CandidateDiscovery.CategoryKeys)
                                    {
                                        <input type="hidden" name="CandidateDiscovery.CategoryKeys" value="@categoryKey" />
                                    }
                                    <input type="hidden" asp-for="CandidateDiscovery.Locale" />
                                    <input type="hidden" asp-for="CandidateDiscovery.Market" />
                                    <input type="hidden" asp-for="CandidateDiscovery.BrandHints" />
                                    <input type="hidden" asp-for="CandidateDiscovery.AutomationMode" />
                                    <input type="hidden" asp-for="CandidateDiscovery.MaxCandidates" />
                                    @foreach (var dismissedCandidateKey in Model.CandidateDiscovery.DismissedCandidateKeys)
                                    {
                                        <input type="hidden" name="CandidateDiscovery.DismissedCandidateKeys" value="@dismissedCandidateKey" />
                                    }
                                    <button type="submit" class="btn btn-dark">Accept candidate</button>
                                </form>
                            }

                            <form method="post" asp-page-handler="DismissCandidate">
                                <input type="hidden" asp-for="CandidateSelection.CandidateKey" value="@candidate.CandidateKey" />
                                <input type="hidden" asp-for="CandidateSelection.DisplayName" value="@candidate.DisplayName" />
                                @foreach (var categoryKey in Model.CandidateDiscovery.CategoryKeys)
                                {
                                    <input type="hidden" name="CandidateDiscovery.CategoryKeys" value="@categoryKey" />
                                }
                                <input type="hidden" asp-for="CandidateDiscovery.Locale" />
                                <input type="hidden" asp-for="CandidateDiscovery.Market" />
                                <input type="hidden" asp-for="CandidateDiscovery.BrandHints" />
                                <input type="hidden" asp-for="CandidateDiscovery.AutomationMode" />
                                <input type="hidden" asp-for="CandidateDiscovery.MaxCandidates" />
                                @foreach (var dismissedCandidateKey in Model.CandidateDiscovery.DismissedCandidateKeys)
                                {
                                    <input type="hidden" name="CandidateDiscovery.DismissedCandidateKeys" value="@dismissedCandidateKey" />
                                }
                                <button type="submit" class="btn btn-outline-secondary">Dismiss candidate</button>
                            </form>
                        </div>

                        <p class="subtle-copy mt-2 mb-0">Use candidate keeps the registration form editable. Accept candidate is only shown for recommended candidates and still registers through the same source registration pipeline.</p>
                    </article>
                }
                </div>
            }

            @if (archivedCandidates.Count > 0)
            {
                <details class="candidate-archive-disclosure mt-3">
                    <summary>Archived for this run (@archivedCandidates.Count)</summary>

                    <div class="job-card-grid mt-3">
                    @foreach (var candidate in archivedCandidates)
                    {
                        <article class="job-card">
                            <div class="job-card-header">
                                <div>
                                    <strong>@candidate.DisplayName</strong>
                                    <div class="subtle-copy mono">@candidate.Host</div>
                                    <div class="subtle-copy">Archived from the active review queue for this discovery run.</div>
                                </div>
                                <partial name="_StatusBadge" model='new ProductNormaliser.Web.Models.StatusBadgeModel { Text = "Archived", Tone = "pending" }' />
                            </div>

                            <div class="actions-bar">
                                <form method="post" asp-page-handler="RestoreCandidate">
                                    <input type="hidden" asp-for="CandidateSelection.CandidateKey" value="@candidate.CandidateKey" />
                                    <input type="hidden" asp-for="CandidateSelection.DisplayName" value="@candidate.DisplayName" />
                                    @foreach (var categoryKey in Model.CandidateDiscovery.CategoryKeys)
                                    {
                                        <input type="hidden" name="CandidateDiscovery.CategoryKeys" value="@categoryKey" />
                                    }
                                    <input type="hidden" asp-for="CandidateDiscovery.Locale" />
                                    <input type="hidden" asp-for="CandidateDiscovery.Market" />
                                    <input type="hidden" asp-for="CandidateDiscovery.BrandHints" />
                                    <input type="hidden" asp-for="CandidateDiscovery.AutomationMode" />
                                    <input type="hidden" asp-for="CandidateDiscovery.MaxCandidates" />
                                    @foreach (var dismissedCandidateKey in Model.CandidateDiscovery.DismissedCandidateKeys)
                                    {
                                        <input type="hidden" name="CandidateDiscovery.DismissedCandidateKeys" value="@dismissedCandidateKey" />
                                    }
                                    <button type="submit" class="btn btn-outline-secondary">Restore candidate</button>
                                </form>
                            </div>
                        </article>
                    }
                    </div>
                </details>
            }
        </section>
    }

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Filters</p>
                <h2>Refine the operational source registry</h2>
            </div>
        </div>

        <form method="get" class="filters-bar">
            <div>
                <label asp-for="Search" class="form-label">Search</label>
                <input asp-for="Search" class="form-control" placeholder="Source id, name, or host" />
            </div>
            <div>
                <label asp-for="CategoryKey" class="form-label">Category</label>
                <select asp-for="CategoryKey" class="form-select">
                    <option value="">All categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryKey">@category.DisplayName</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Enabled" class="form-label">Status</label>
                <select asp-for="Enabled" class="form-select">
                    <option value="">Any</option>
                    <option value="true">Enabled</option>
                    <option value="false">Disabled</option>
                </select>
            </div>
            <div class="actions-bar">
                <button type="submit" class="btn btn-dark">Apply Filters</button>
                <a asp-page="/Sources/Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </section>

    <section class="panel panel-muted">
        <div class="metric-strip">
            <article>
                <span>Ready sources</span>
                <strong>@Model.ReadySources</strong>
            </article>
            <article>
                <span>Need attention</span>
                <strong>@Model.AttentionSources</strong>
            </article>
            <article>
                <span>Enabled in view</span>
                <strong>@Model.Sources.Count(source => source.IsEnabled)</strong>
            </article>
            <article>
                <span>Discovery backlog</span>
                <strong>@Model.DiscoveryBacklogSources</strong>
            </article>
        </div>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Sources</p>
                <h2>Managed source hosts and health</h2>
            </div>
        </div>

        @if (Model.Sources.Count == 0)
        {
            <div class="empty-panel">
                <p class="empty-state">No sources match the current filters.</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table dashboard-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Categories</th>
                            <th>Discovery posture</th>
                            <th>Discovery 24h</th>
                            <th>Throttling</th>
                            <th>Crawl readiness</th>
                            <th>Health</th>
                            <th>Last crawl</th>
                            <th>Status</th>
                            <th class="actions-col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var source in Model.Sources)
                    {
                        <tr>
                            <td>
                                <strong>@source.DisplayName</strong>
                                <div class="text-muted small mono">@source.SourceId</div>
                                <div class="text-muted small">@source.Host</div>
                            </td>
                            <td>
                                <div class="chip-row compact-wrap">
                                @foreach (var categoryLabel in Model.GetAssignedCategoryLabels(source))
                                {
                                    <span class="chip">@categoryLabel</span>
                                }
                                </div>
                            </td>
                            <td>
                                <div>Queue @source.DiscoveryQueueDepth</div>
                                <div class="text-muted small">sitemap @(source.SitemapReachable ? "reachable" : "unverified"), robots @(source.ThrottlingPolicy.RespectRobotsTxt ? "on" : "off")</div>
                                <div class="text-muted small">@Model.GetSetupSummary(source)</div>
                            </td>
                            <td>
                                <div>@source.ConfirmedProductUrlsLast24Hours confirmed products</div>
                                <div class="text-muted small">@source.ListingPagesVisitedLast24Hours listings, @source.SitemapUrlsProcessedLast24Hours sitemaps</div>
                            </td>
                            <td>
                                <div>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatThrottlingProfile(source.ThrottlingPolicy)</div>
                                <div class="text-muted small">robots @(source.ThrottlingPolicy.RespectRobotsTxt ? "on" : "off")</div>
                            </td>
                            <td>
                                <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetReadinessBadge(source.Readiness)" />
                                <div class="text-muted small">@source.Readiness.Summary</div>
                            </td>
                            <td>
                                <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetHealthBadge(source.Health)" />
                                <div class="text-muted small">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatHealthSummary(source.Health)</div>
                                <div class="mt-2">
                                    <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetAutomationBadge(source.Health)" />
                                </div>
                                <div class="text-muted small">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationSummary(source.Health)</div>
                                @if (!string.IsNullOrWhiteSpace(ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationReasons(source.Health)))
                                {
                                    <div class="text-muted small">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationReasons(source.Health)</div>
                                }
                            </td>
                            <td>
                                <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetLastActivityBadge(source.LastActivity)" />
                                <div class="text-muted small">@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatLastActivity(source.LastActivity)</div>
                            </td>
                            <td>
                                <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetEnabledBadge(source.IsEnabled)" />
                            </td>
                            <td class="actions-col">
                                <form method="post" asp-page-handler="Toggle" class="inline-form">
                                    <input type="hidden" name="sourceId" value="@source.SourceId" />
                                    <input type="hidden" name="currentlyEnabled" value="@source.IsEnabled" />
                                    <input type="hidden" name="category" value="@Model.CategoryKey" />
                                    <input type="hidden" name="search" value="@Model.Search" />
                                    <input type="hidden" name="enabled" value="@Model.Enabled" />
                                    <button type="submit" class="btn @(source.IsEnabled ? "btn-outline-danger" : "btn-outline-success") btn-sm">@(source.IsEnabled ? "Disable" : "Enable")</button>
                                </form>
                                <a class="btn btn-outline-dark btn-sm" asp-page="/Sources/Details" asp-route-sourceId="@source.SourceId">Manage</a>
                                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildIntelligenceUrl(source)">Health</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>