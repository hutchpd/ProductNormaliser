@page "{sourceId}"
@model ProductNormaliser.Web.Pages.Sources.DetailsModel
@{
    ViewData["Title"] = Model.CurrentSource is null ? "Source" : Model.CurrentSource.DisplayName;
}

<section class="dashboard-shell">
    <div class="hero-panel">
        <div>
            <p class="eyebrow">Source Management</p>
            <h1>@(Model.CurrentSource?.DisplayName ?? "Unknown Source")</h1>
            <p class="hero-copy">This page combines source configuration with operational readiness, recent health signals, and latest crawl activity so operators can decide whether a source is safe to leave enabled.</p>
        </div>
        @if (Model.CurrentSource is not null)
        {
            <div class="hero-metrics">
                <article>
                    <span>Host</span>
                    <strong>@Model.CurrentSource.Host</strong>
                </article>
                <article>
                    <span>Readiness</span>
                    <strong>@Model.CurrentSource.Readiness.Status</strong>
                </article>
                <article>
                    <span>Health</span>
                    <strong>@Model.CurrentSource.Health.Status</strong>
                </article>
                <article>
                    <span>Last crawl</span>
                    <strong>@(Model.CurrentSource.LastActivity is null ? "None" : Model.CurrentSource.LastActivity.TimestampUtc.ToString("u"))</strong>
                </article>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice error">@Model.ErrorMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="notice error" role="alert"></div>

    @if (Model.CurrentSource is null)
    {
        <div class="panel">
            <p class="empty-state">The requested source could not be loaded.</p>
        </div>
    }
    else
    {
        <div class="source-detail-grid">
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Analyst Notes</p>
                        <h2>Internal source note</h2>
                        <p class="subtle-copy">Keep lightweight review context for supplier quirks, manual checks, or escalation history.</p>
                    </div>
                    @if (Model.AnalystNote is not null)
                    {
                        <span class="status-pill completed">Updated @Model.AnalystNote.UpdatedUtc.ToString("u")</span>
                    }
                </div>

                <form method="post" asp-page-handler="SaveNote" class="source-form">
                    <div class="form-grid">
                        <div>
                            <label asp-for="NoteInput.Title" class="form-label"></label>
                            <input asp-for="NoteInput.Title" class="form-control" placeholder="Why this source needs attention" />
                            <span asp-validation-for="NoteInput.Title" class="text-danger small"></span>
                        </div>
                        <div class="wide">
                            <label asp-for="NoteInput.Content" class="form-label"></label>
                            <textarea asp-for="NoteInput.Content" rows="4" class="form-control" placeholder="Observed crawl issue, data quality note, or analyst handoff"></textarea>
                            <span asp-validation-for="NoteInput.Content" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Save note</button>
                        @if (Model.AnalystNote is not null)
                        {
                            <button type="submit" asp-page-handler="DeleteNote" class="btn btn-outline-danger">Delete note</button>
                        }
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Identity</p>
                        <h2>Edit core source settings</h2>
                    </div>
                    <div class="inline-actions">
                        <partial name="_StatusBadge" model="ProductNormaliser.Web.Models.SourceManagementPresentation.GetEnabledBadge(Model.CurrentSource.IsEnabled)" />
                        <form method="post" asp-page-handler="Toggle" class="inline-form">
                            <input type="hidden" name="currentlyEnabled" value="@Model.CurrentSource.IsEnabled" />
                            <button type="submit" class="btn @(Model.CurrentSource.IsEnabled ? "btn-outline-danger" : "btn-outline-success")">
                                @(Model.CurrentSource.IsEnabled ? "Disable source" : "Enable source")
                            </button>
                        </form>
                    </div>
                </div>

                <form method="post" asp-page-handler="Update" class="source-form">
                    <div class="form-grid">
                        <div>
                            <label asp-for="Source.DisplayName" class="form-label"></label>
                            <input asp-for="Source.DisplayName" class="form-control" />
                            <span asp-validation-for="Source.DisplayName" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Source.BaseUrl" class="form-label"></label>
                            <input asp-for="Source.BaseUrl" class="form-control" />
                            <span asp-validation-for="Source.BaseUrl" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Source.PreferredLocale" class="form-label"></label>
                            <input asp-for="Source.PreferredLocale" class="form-control" />
                        </div>
                        <div>
                            <label asp-for="Source.AutomationMode" class="form-label"></label>
                            <select asp-for="Source.AutomationMode" class="form-control">
                                <option value="operator_assisted">Operator-assisted</option>
                                <option value="suggest_accept">Suggest accept</option>
                                <option value="auto_accept_and_seed">Auto-accept and seed</option>
                            </select>
                        </div>
                        <div class="wide">
                            <label asp-for="Source.Description" class="form-label"></label>
                            <textarea asp-for="Source.Description" rows="3" class="form-control"></textarea>
                        </div>
                    </div>
                    <div class="check-grid compact-grid">
                        @foreach (var market in new[] { "UK", "IE", "EU", "US" })
                        {
                            <label class="check-card">
                                <input type="checkbox" name="Source.AllowedMarkets" value="@market" checked="@Model.Source.AllowedMarkets.Contains(market, StringComparer.OrdinalIgnoreCase)" />
                                <span>
                                    <strong>@market</strong>
                                    <span class="subtle-copy d-block">Approved onboarding market</span>
                                </span>
                            </label>
                        }
                    </div>
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Save Source</button>
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Operational Readiness</p>
                        <h2>Current crawl support and health</h2>
                    </div>
                    <a href="@Model.IntelligenceUrl" class="btn btn-outline-dark">Open source intelligence</a>
                </div>

                <div class="metric-strip">
                    <article>
                        <span>Readiness</span>
                        <strong>@Model.CurrentSource.Readiness.Status</strong>
                    </article>
                    <article>
                        <span>Health</span>
                        <strong>@Model.CurrentSource.Health.Status</strong>
                    </article>
                    <article>
                        <span>Trust</span>
                        <strong>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(Model.CurrentSource.Health.TrustScore)</strong>
                    </article>
                    <article>
                        <span>Fetch success</span>
                        <strong>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(Model.CurrentSource.Health.SuccessfulCrawlRate)</strong>
                    </article>
                    <article>
                        <span>Extractability</span>
                        <strong>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(Model.CurrentSource.Health.ExtractabilityRate)</strong>
                    </article>
                    <article>
                        <span>No-product rate</span>
                        <strong>@ProductNormaliser.Web.Models.AnalyticsPresentation.FormatPercent(Model.CurrentSource.Health.NoProductRate)</strong>
                    </article>
                    <article>
                        <span>Automation posture</span>
                        <strong>@ProductNormaliser.Web.Models.SourceManagementPresentation.GetAutomationBadge(Model.CurrentSource.Health).Text</strong>
                    </article>
                </div>

                <dl class="detail-grid">
                    <div>
                        <dt>Readiness summary</dt>
                        <dd>@Model.CurrentSource.Readiness.Summary</dd>
                    </div>
                    <div>
                        <dt>Allowed markets</dt>
                        <dd>@string.Join(", ", Model.CurrentSource.AllowedMarkets)</dd>
                    </div>
                    <div>
                        <dt>Preferred locale</dt>
                        <dd>@Model.CurrentSource.PreferredLocale</dd>
                    </div>
                    <div>
                        <dt>Automation mode</dt>
                        <dd>@Model.CurrentSource.AutomationPolicy.Mode.Replace('_', ' ')</dd>
                    </div>
                    <div>
                        <dt>Effective automation mode</dt>
                        <dd>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationMode(Model.CurrentSource.Health.Automation.EffectiveMode)</dd>
                    </div>
                    <div>
                        <dt>Recommended action</dt>
                        <dd>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationAction(Model.CurrentSource.Health.Automation.RecommendedAction)</dd>
                    </div>
                    <div>
                        <dt>Last health snapshot</dt>
                        <dd>@(Model.CurrentSource.Health.SnapshotUtc?.ToString("u") ?? "No snapshot recorded")</dd>
                    </div>
                    <div>
                        <dt>Recent health</dt>
                        <dd>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatHealthSummary(Model.CurrentSource.Health)</dd>
                    </div>
                    <div>
                        <dt>Automation summary</dt>
                        <dd>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationSummary(Model.CurrentSource.Health)</dd>
                    </div>
                    <div>
                        <dt>Automation reasons</dt>
                        <dd>@(string.IsNullOrWhiteSpace(ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationReasons(Model.CurrentSource.Health)) ? "No supporting or blocking reasons recorded." : ProductNormaliser.Web.Models.SourceManagementPresentation.FormatAutomationReasons(Model.CurrentSource.Health))</dd>
                    </div>
                    <div>
                        <dt>Last crawl activity</dt>
                        <dd>@ProductNormaliser.Web.Models.SourceManagementPresentation.FormatLastActivity(Model.CurrentSource.LastActivity)</dd>
                    </div>
                    <div>
                        <dt>Last extraction outcome</dt>
                        <dd>@(Model.CurrentSource.LastActivity is null ? "No crawl recorded" : Model.CurrentSource.LastActivity.ExtractionOutcome.Replace('_', ' '))</dd>
                    </div>
                </dl>

                @if (Model.CurrentSource.Health.Automation.SupportingReasons.Count > 0 || Model.CurrentSource.Health.Automation.BlockingReasons.Count > 0)
                {
                    <div class="panel-section mt-3">
                        <div class="subtle-copy">Automation evidence</div>
                        <ul class="small mb-0">
                            @foreach (var reason in Model.CurrentSource.Health.Automation.SupportingReasons)
                            {
                                <li>@reason</li>
                            }
                            @foreach (var reason in Model.CurrentSource.Health.Automation.BlockingReasons)
                            {
                                <li>@reason</li>
                            }
                        </ul>
                    </div>
                }
            </section>

            <section class="panel panel-muted">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Discovery Posture</p>
                        <h2>Deterministic discovery coverage</h2>
                    </div>
                </div>

                <div class="metric-strip">
                    <article>
                        <span>Profile configured</span>
                        <strong>@(Model.HasDiscoveryProfileConfigured ? "Yes" : "No")</strong>
                    </article>
                    <article>
                        <span>Sitemap reachable</span>
                        <strong>@(Model.CurrentSource.SitemapReachable ? "Yes" : "No")</strong>
                    </article>
                    <article>
                        <span>Discovery queue</span>
                        <strong>@Model.CurrentSource.DiscoveryQueueDepth</strong>
                    </article>
                    <article>
                        <span>Last discovery</span>
                        <strong>@(Model.CurrentSource.LastDiscoveryUtc?.ToString("u") ?? "No activity")</strong>
                    </article>
                </div>

                <dl class="detail-grid">
                    <div>
                        <dt>Entry pages configured</dt>
                        <dd>@Model.ConfiguredEntryPageCount</dd>
                    </div>
                    <div>
                        <dt>Sitemap hints</dt>
                        <dd>@Model.CurrentSource.DiscoveryProfile.SitemapHints.Count</dd>
                    </div>
                    <div>
                        <dt>Listing pages visited 24h</dt>
                        <dd>@Model.CurrentSource.ListingPagesVisitedLast24Hours</dd>
                    </div>
                    <div>
                        <dt>Sitemaps processed 24h</dt>
                        <dd>@Model.CurrentSource.SitemapUrlsProcessedLast24Hours</dd>
                    </div>
                    <div>
                        <dt>Confirmed product URLs 24h</dt>
                        <dd>@Model.CurrentSource.ConfirmedProductUrlsLast24Hours</dd>
                    </div>
                    <div>
                        <dt>Robots respected</dt>
                        <dd>@(Model.CurrentSource.ThrottlingPolicy.RespectRobotsTxt ? "Yes" : "No")</dd>
                    </div>
                </dl>

                @if (Model.DiscoveryCoverageRows.Count == 0)
                {
                    <div class="empty-panel mt-3">
                        <p class="empty-state">No discovery coverage has been recorded for this source yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap mt-3">
                        <table class="table dashboard-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th>Discovery completion</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var coverage in Model.DiscoveryCoverageRows)
                            {
                                <tr>
                                    <td>
                                        <strong class="mono">@coverage.Key</strong>
                                    </td>
                                    <td>@coverage.Value.ToString("0.#")%</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Categories</p>
                        <h2>Assign supported product families</h2>
                    </div>
                </div>

                <form method="post" asp-page-handler="Categories" class="source-form">
                    <div class="check-grid">
                    @foreach (var category in Model.AvailableCategories)
                    {
                        <label class="check-card @(category.IsEnabled ? string.Empty : "disabled")">
                            <input type="checkbox" name="CategoriesForm.CategoryKeys" value="@category.CategoryKey" checked="@Model.CategoriesForm.CategoryKeys.Contains(category.CategoryKey)" />
                            <span>
                                <strong>@category.DisplayName</strong>
                                <span class="subtle-copy d-block">@category.FamilyDisplayName</span>
                                <span class="subtle-copy d-block">@category.CrawlSupportStatus</span>
                            </span>
                        </label>
                    }
                    </div>
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Update Categories</button>
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Throttling</p>
                        <h2>Adjust host crawling policy</h2>
                    </div>
                </div>

                <form method="post" asp-page-handler="Throttling" class="source-form">
                    <div class="form-grid compact-grid">
                        <div>
                            <label asp-for="Throttling.MinDelayMs" class="form-label"></label>
                            <input asp-for="Throttling.MinDelayMs" class="form-control" />
                            <span asp-validation-for="Throttling.MinDelayMs" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Throttling.MaxDelayMs" class="form-label"></label>
                            <input asp-for="Throttling.MaxDelayMs" class="form-control" />
                            <span asp-validation-for="Throttling.MaxDelayMs" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Throttling.MaxConcurrentRequests" class="form-label"></label>
                            <input asp-for="Throttling.MaxConcurrentRequests" class="form-control" />
                            <span asp-validation-for="Throttling.MaxConcurrentRequests" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Throttling.RequestsPerMinute" class="form-label"></label>
                            <input asp-for="Throttling.RequestsPerMinute" class="form-control" />
                            <span asp-validation-for="Throttling.RequestsPerMinute" class="text-danger small"></span>
                        </div>
                    </div>
                    <label class="form-check">
                        <input asp-for="Throttling.RespectRobotsTxt" class="form-check-input" />
                        <span class="form-check-label">Respect robots.txt before crawling</span>
                    </label>
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Save Throttling</button>
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Discovery Profile</p>
                        <h2>Configure sitemap and listing discovery</h2>
                        <p class="subtle-copy">Define where deterministic discovery should begin for each category and what URL shapes should be traversed or promoted into the product crawl queue.</p>
                    </div>
                </div>

                <form method="post" asp-page-handler="Discovery" class="source-form">
                    <div class="form-grid">
                        <div class="wide">
                            <label asp-for="Discovery.CategoryEntryPages" class="form-label"></label>
                            <textarea asp-for="Discovery.CategoryEntryPages" rows="5" class="form-control" placeholder="tv=/televisions, /oled&#10;monitor=/monitors"></textarea>
                            <div class="subtle-copy">One line per category in <code>category=url1, url2</code> format.</div>
                            <span asp-validation-for="Discovery.CategoryEntryPages" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.SitemapHints" class="form-label"></label>
                            <textarea asp-for="Discovery.SitemapHints" rows="4" class="form-control" placeholder="/sitemap.xml&#10;/sitemap-products.xml"></textarea>
                            <span asp-validation-for="Discovery.SitemapHints" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.AllowedHosts" class="form-label"></label>
                            <textarea asp-for="Discovery.AllowedHosts" rows="4" class="form-control" placeholder="cdn.alpha.example&#10;images.alpha.example"></textarea>
                            <div class="subtle-copy">Optional extra hosts discovery may traverse in addition to the source base host. Explicit hosts override the runtime market and locale heuristics.</div>
                            <span asp-validation-for="Discovery.AllowedHosts" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.AllowedPathPrefixes" class="form-label"></label>
                            <textarea asp-for="Discovery.AllowedPathPrefixes" rows="4" class="form-control" placeholder="/tv&#10;/product"></textarea>
                            <div class="subtle-copy">Explicit path prefixes override runtime market and locale heuristics for matching URLs.</div>
                            <span asp-validation-for="Discovery.AllowedPathPrefixes" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.ExcludedPathPrefixes" class="form-label"></label>
                            <textarea asp-for="Discovery.ExcludedPathPrefixes" rows="4" class="form-control" placeholder="/support&#10;/help"></textarea>
                            <span asp-validation-for="Discovery.ExcludedPathPrefixes" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.ProductUrlPatterns" class="form-label"></label>
                            <textarea asp-for="Discovery.ProductUrlPatterns" rows="4" class="form-control" placeholder="/product/&#10;/p/"></textarea>
                            <span asp-validation-for="Discovery.ProductUrlPatterns" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.ListingUrlPatterns" class="form-label"></label>
                            <textarea asp-for="Discovery.ListingUrlPatterns" rows="4" class="form-control" placeholder="/category/&#10;/department/"></textarea>
                            <span asp-validation-for="Discovery.ListingUrlPatterns" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="form-grid compact-grid">
                        <div>
                            <label asp-for="Discovery.MaxDiscoveryDepth" class="form-label"></label>
                            <input asp-for="Discovery.MaxDiscoveryDepth" class="form-control" />
                            <span asp-validation-for="Discovery.MaxDiscoveryDepth" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.MaxUrlsPerRun" class="form-label"></label>
                            <input asp-for="Discovery.MaxUrlsPerRun" class="form-control" />
                            <span asp-validation-for="Discovery.MaxUrlsPerRun" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.MaxRetryCount" class="form-label"></label>
                            <input asp-for="Discovery.MaxRetryCount" class="form-control" />
                            <span asp-validation-for="Discovery.MaxRetryCount" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.RetryBackoffBaseMs" class="form-label"></label>
                            <input asp-for="Discovery.RetryBackoffBaseMs" class="form-control" />
                            <span asp-validation-for="Discovery.RetryBackoffBaseMs" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Discovery.RetryBackoffMaxMs" class="form-label"></label>
                            <input asp-for="Discovery.RetryBackoffMaxMs" class="form-control" />
                            <span asp-validation-for="Discovery.RetryBackoffMaxMs" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="actions-bar">
                        <button type="submit" class="btn btn-dark">Save Discovery Profile</button>
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Audit</p>
                        <h2>Current source snapshot</h2>
                    </div>
                </div>

                <dl class="detail-grid">
                    <div>
                        <dt>Source ID</dt>
                        <dd>@Model.CurrentSource.SourceId</dd>
                    </div>
                    <div>
                        <dt>Updated</dt>
                        <dd>@Model.CurrentSource.UpdatedUtc.ToString("u")</dd>
                    </div>
                    <div>
                        <dt>Created</dt>
                        <dd>@Model.CurrentSource.CreatedUtc.ToString("u")</dd>
                    </div>
                    <div>
                        <dt>Current categories</dt>
                        <dd>@string.Join(", ", Model.AssignedCategoryLabels)</dd>
                    </div>
                    <div>
                        <dt>Crawlable categories</dt>
                        <dd>@Model.CurrentSource.Readiness.CrawlableCategoryCount / @Model.CurrentSource.Readiness.AssignedCategoryCount</dd>
                    </div>
                    <div>
                        <dt>Latest crawl status</dt>
                        <dd>@(Model.CurrentSource.LastActivity?.Status ?? "No recent crawl")</dd>
                    </div>
                </dl>
            </section>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}